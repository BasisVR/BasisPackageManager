<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <ResourceDictionary>
            <Color x:Key="BasisBackground">#100F27</Color>
            <Color x:Key="BasisPanel">#15142E</Color>
            <Color x:Key="BasisSurface">#1A1937</Color>
            <Color x:Key="BasisSurfaceHover">#221F44</Color>
            <Color x:Key="BasisSurfaceMuted">#13122B</Color>

            <Color x:Key="BasisBorder">#1AFFFFFF</Color>
            <Color x:Key="BasisBorderStrong">#33FFFFFF</Color>

            <!-- Translucent "glass" fills: a frosted light film over the animated background,
                 mirroring the website's bg-white/5 cards. -->
            <Color x:Key="BasisGlass">#14FFFFFF</Color>
            <Color x:Key="BasisGlassStrong">#1FFFFFFF</Color>

            <Color x:Key="BasisTextPrimary">#F4F2FF</Color>
            <Color x:Key="BasisTextMuted">#B7B3D6</Color>
            <Color x:Key="BasisTextSecondary">#9C97C2</Color>
            <Color x:Key="BasisTextDim">#6E699A</Color>

            <Color x:Key="BasisBrand">#EF1237</Color>
            <Color x:Key="BasisBrandHover">#FF2C50</Color>
            <Color x:Key="BasisBrandPressed">#C81030</Color>
            <Color x:Key="BasisBrandSoft">#3FEF1237</Color>

            <Color x:Key="BasisPurple">#9333EA</Color>
            <Color x:Key="BasisBlue">#3B82F6</Color>
            <Color x:Key="BasisPink">#EC4899</Color>

            <Color x:Key="BasisDanger">#EF1237</Color>
            <Color x:Key="BasisSuccess">#22C55E</Color>
            <Color x:Key="BasisWarning">#F59E0B</Color>

            <SolidColorBrush x:Key="BasisBackgroundBrush" Color="{StaticResource BasisBackground}"/>
            <SolidColorBrush x:Key="BasisPanelBrush" Color="{StaticResource BasisPanel}"/>
            <SolidColorBrush x:Key="BasisSurfaceBrush" Color="{StaticResource BasisSurface}"/>
            <SolidColorBrush x:Key="BasisSurfaceHoverBrush" Color="{StaticResource BasisSurfaceHover}"/>
            <SolidColorBrush x:Key="BasisSurfaceMutedBrush" Color="{StaticResource BasisSurfaceMuted}"/>
            <SolidColorBrush x:Key="BasisBorderBrush" Color="{StaticResource BasisBorder}"/>
            <SolidColorBrush x:Key="BasisBorderStrongBrush" Color="{StaticResource BasisBorderStrong}"/>
            <SolidColorBrush x:Key="BasisGlassBrush" Color="{StaticResource BasisGlass}"/>
            <SolidColorBrush x:Key="BasisGlassStrongBrush" Color="{StaticResource BasisGlassStrong}"/>
            <!-- Override the Fluent ComboBox dropdown-popup fill to the dark scheme (backup for the
                 ComboBox /template/ Border#PopupBorder selector); Fluent's default is light/translucent. -->
            <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{StaticResource BasisSurface}"/>
            <SolidColorBrush x:Key="BasisTextPrimaryBrush" Color="{StaticResource BasisTextPrimary}"/>
            <SolidColorBrush x:Key="BasisTextMutedBrush" Color="{StaticResource BasisTextMuted}"/>
            <SolidColorBrush x:Key="BasisTextSecondaryBrush" Color="{StaticResource BasisTextSecondary}"/>
            <SolidColorBrush x:Key="BasisTextDimBrush" Color="{StaticResource BasisTextDim}"/>
            <SolidColorBrush x:Key="BasisBrandBrush" Color="{StaticResource BasisBrand}"/>
            <SolidColorBrush x:Key="BasisBrandHoverBrush" Color="{StaticResource BasisBrandHover}"/>
            <SolidColorBrush x:Key="BasisBrandPressedBrush" Color="{StaticResource BasisBrandPressed}"/>
            <SolidColorBrush x:Key="BasisPurpleBrush" Color="{StaticResource BasisPurple}"/>
            <SolidColorBrush x:Key="BasisBlueBrush" Color="{StaticResource BasisBlue}"/>
            <SolidColorBrush x:Key="BasisPinkBrush" Color="{StaticResource BasisPink}"/>
            <SolidColorBrush x:Key="BasisDangerBrush" Color="{StaticResource BasisDanger}"/>
            <SolidColorBrush x:Key="BasisSuccessBrush" Color="{StaticResource BasisSuccess}"/>
            <SolidColorBrush x:Key="BasisWarningBrush" Color="{StaticResource BasisWarning}"/>

            <SolidColorBrush x:Key="BasisAccentBrush" Color="{StaticResource BasisBrand}"/>

            <!-- Monospace stack for code / logs / git URLs / diffs. Avalonia doesn't resolve the CSS
                 generic "monospace", so real family names for all three desktop OSes are listed: Windows
                 (Cascadia/Consolas), macOS (Menlo/Monaco), Linux (DejaVu/Liberation/Ubuntu/Noto). Without
                 this, those fields fall back to the proportional UI font on Linux. -->
            <FontFamily x:Key="MonoFontFamily">Cascadia Mono, Cascadia Code, Consolas, Menlo, Monaco, DejaVu Sans Mono, Liberation Mono, Ubuntu Mono, Noto Sans Mono, Courier New, monospace</FontFamily>

            <LinearGradientBrush x:Key="BasisAnimatedGradient" StartPoint="100%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#EF1237"/>
                <GradientStop Offset="0.33" Color="#9333EA"/>
                <GradientStop Offset="0.66" Color="#3B82F6"/>
                <GradientStop Offset="1" Color="#F43F5E"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="BasisHeroGradient" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#33EF1237"/>
                <GradientStop Offset="0.5" Color="#26EC4899"/>
                <GradientStop Offset="1" Color="#269333EA"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="BasisBrandGradient" StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Offset="0" Color="#EF1237"/>
                <GradientStop Offset="1" Color="#9333EA"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="BasisBrandGradientHover" StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Offset="0" Color="#FF2C50"/>
                <GradientStop Offset="1" Color="#A855F7"/>
            </LinearGradientBrush>

            <!-- Expander reskin: the Fluent defaults (opaque header surface, blue-grey chevron)
                 clash with the glass theme. Override its theme resources to match the cards. -->
            <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderHeaderBackgroundPointerOver" Color="{StaticResource BasisSurfaceHover}"/>
            <SolidColorBrush x:Key="ExpanderHeaderBackgroundPressed" Color="{StaticResource BasisSurfaceHover}"/>
            <SolidColorBrush x:Key="ExpanderHeaderBackgroundDisabled" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderHeaderForeground" Color="{StaticResource BasisTextPrimary}"/>
            <SolidColorBrush x:Key="ExpanderHeaderForegroundPointerOver" Color="{StaticResource BasisTextPrimary}"/>
            <SolidColorBrush x:Key="ExpanderHeaderForegroundPressed" Color="{StaticResource BasisTextPrimary}"/>
            <SolidColorBrush x:Key="ExpanderHeaderForegroundDisabled" Color="{StaticResource BasisTextDim}"/>
            <SolidColorBrush x:Key="ExpanderHeaderBorderBrush" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderHeaderBorderBrushPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderHeaderBorderBrushPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderHeaderBorderBrushDisabled" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderContentBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="{StaticResource BasisBorder}"/>
            <SolidColorBrush x:Key="ExpanderChevronForeground" Color="{StaticResource BasisTextMuted}"/>
            <SolidColorBrush x:Key="ExpanderChevronForegroundPointerOver" Color="{StaticResource BasisBrand}"/>
            <SolidColorBrush x:Key="ExpanderChevronForegroundPressed" Color="{StaticResource BasisBrand}"/>
            <SolidColorBrush x:Key="ExpanderChevronForegroundDisabled" Color="{StaticResource BasisTextDim}"/>
            <SolidColorBrush x:Key="ExpanderChevronBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderChevronBackgroundPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderChevronBackgroundPressed" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderChevronBorderBrush" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderChevronBorderBrushPointerOver" Color="Transparent"/>
            <SolidColorBrush x:Key="ExpanderChevronBorderBrushPressed" Color="Transparent"/>
        </ResourceDictionary>
    </Styles.Resources>

    <Style Selector="Window">
        <Setter Property="Background" Value="{StaticResource BasisBackgroundBrush}"/>
        <Setter Property="FontFamily" Value="fonts:Inter#Inter"/>
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>

    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="36"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="LetterSpacing" Value="-0.5"/>
        <Setter Property="Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>

    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.h3">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{StaticResource BasisTextMutedBrush}"/>
    </Style>

    <Style Selector="TextBlock.dim">
        <Setter Property="Foreground" Value="{StaticResource BasisTextDimBrush}"/>
    </Style>

    <Style Selector="TextBlock.tagline">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="LetterSpacing" Value="3"/>
        <Setter Property="Foreground" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="TextBlock.brand">
        <Setter Property="Foreground" Value="{StaticResource BasisBrandBrush}"/>
    </Style>

    <!-- Frosted "glass" card: a translucent film that lets the animated background wash through,
         matching the website's bg-white/5 backdrop-blur cards. -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource BasisGlassBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Padding" Value="22"/>
    </Style>

    <!-- Opt-in glass surface for panels / rows nested inside a card. -->
    <Style Selector="Border.glass">
        <Setter Property="Background" Value="{StaticResource BasisGlassStrongBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{StaticResource BasisPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>

    <Style Selector="Button">
        <!-- Idle fill = the hover fill at ZERO alpha, NOT Transparent. Avalonia's `Transparent` is
             transparent WHITE (#00FFFFFF), so a BrushTransition from it interpolates RGB from white —
             the "transparent -> white -> blue" wash. Matching the hover RGB (#221F44) at alpha 00
             means the transition ramps only opacity, so the fill fades straight in as navy. -->
        <Setter Property="Background" Value="#00221F44"/>
        <Setter Property="Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBorderStrongBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="18,9"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>

    <!-- Smooth every button's hover/press. The :pointerover colour changes target the templated
         ContentPresenter, so the colour transitions live there. The subtle press-shrink uses a
         TransformOperationsTransition (the transitions subsystem DOES interpolate ITransform —
         unlike the keyframe Animation animator, which throws "No animator for RenderTransform";
         see project_basispm_avalonia_animation_gotcha). -->
    <Style Selector="Button /template/ ContentPresenter">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                <BrushTransition Property="TextElement.Foreground" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button:pressed">
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>
    <!-- Inline text links have no chrome to press, so don't shrink them. -->
    <Style Selector="Button.link:pressed">
        <Setter Property="RenderTransform" Value="none"/>
    </Style>

    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisBrandBrush}"/>
    </Style>

    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBrandBrush}"/>
    </Style>

    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisBrandHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBrandHoverBrush}"/>
        <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.primary:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisBrandPressedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBrandPressedBrush}"/>
        <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- Secondary action: a calm, filled neutral button for already-handled states such as the
         "Manage" menu on an installed package. Has the presence of a primary button without the
         brand-red that reads as either the main CTA or a destructive action. -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBorderStrongBrush}"/>
    </Style>

    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>

    <Style Selector="Button.secondary:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceMutedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>

    <Style Selector="Button.cta">
        <Setter Property="Background" Value="{StaticResource BasisBrandGradient}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="22,11"/>
    </Style>

    <Style Selector="Button.cta /template/ ContentPresenter">
        <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.cta:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisBrandGradientHover}"/>
        <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.danger">
        <!-- Idle = brand-red at zero alpha (not the inherited navy) so hover fades in cleanly as red. -->
        <Setter Property="Background" Value="#00EF1237"/>
        <Setter Property="Foreground" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBrandBrush}"/>
    </Style>

    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- Square icon-only button for dense, repeated toolbar actions (refresh, copy, delete,
         close, open-folder, open-link, add). The child is a single PathIcon; because a PathIcon's
         Foreground inherits the ambient TextElement.Foreground, the glyph recolours on hover/press
         exactly like a text label does — so these need no per-state icon styling. Every usage
         carries a ToolTip.Tip naming the action (usually its former text label) for discoverability. -->
    <Style Selector="Button.iconBtn">
        <Setter Property="Padding" Value="9"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>
    <!-- Tighter variant for compact strips such as the status bar. -->
    <Style Selector="Button.iconBtn.sm">
        <Setter Property="Padding" Value="7"/>
    </Style>

    <!-- Sizing for a leading icon that sits next to a text label inside a button or nav item.
         Kept small so it reads as an accent, not a second focal point. -->
    <Style Selector="PathIcon.leadingIcon">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
    </Style>

    <Style Selector="Button.nav">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="20,11"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Foreground" Value="{StaticResource BasisTextSecondaryBrush}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="Button.nav.active">
        <Setter Property="Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>

    <Style Selector="Button.nav.active /template/ ContentPresenter">
        <Setter Property="Background" Value="#14FFFFFF"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceMutedBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="SelectionBrush" Value="{StaticResource BasisBrandBrush}"/>
    </Style>

    <!-- Ease the focus-ring colour in/out instead of snapping. -->
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource BasisBrandBrush}"/>
    </Style>

    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Scrollbars: keep them visible and grabbable. The Fluent default auto-hides them (a thin line
         that only fades/expands in on hover), so a user often clicks before the bar has appeared and
         misses it. AllowAutoHide=False keeps each ScrollViewer's bars expanded at all times. -->
    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="False"/>
    </Style>
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="AllowAutoHide" Value="False"/>
    </Style>

    <Style Selector="TextBlock.statusError">
        <Setter Property="Foreground" Value="{StaticResource BasisBrandBrush}"/>
    </Style>

    <Style Selector="TextBlock.statusSuccess">
        <Setter Property="Foreground" Value="{StaticResource BasisSuccessBrush}"/>
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceMutedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="12,9"/>
    </Style>

    <Style Selector="ComboBox /template/ Border#Background">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{StaticResource BasisBrandBrush}"/>
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>
    <!-- Dropdown popup + item states: match the dark scheme. Fluent's defaults are a light/
         translucent popup and a blue accent highlight, which don't match the Basis palette. -->
    <Style Selector="ComboBox /template/ Border#PopupBorder">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBorderStrongBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceHoverBrush}"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceHoverBrush}"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceHoverBrush}"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>

    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>

    <Style Selector="Border.brandBadge">
        <Setter Property="Background" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="10,3"/>
    </Style>

    <!-- Caution pill for packages from an unofficial (user-added) catalog. -->
    <Style Selector="Border.unofficialBadge">
        <Setter Property="Background" Value="#26F59E0B"/>
        <Setter Property="BorderBrush" Value="#80F59E0B"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="8,2"/>
    </Style>

    <Style Selector="Border.versionPill">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceMutedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="10,3"/>
    </Style>

    <!-- Buttons that sit on the brand-gradient update banner -->
    <Style Selector="Button.bannerPrimary">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.bannerPrimary /template/ ContentPresenter">
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisBrandBrush}"/>
    </Style>
    <Style Selector="Button.bannerPrimary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#F1EAF7"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisBrandPressedBrush}"/>
    </Style>

    <Style Selector="Button.bannerGhost">
        <Setter Property="Background" Value="#22FFFFFF"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#55FFFFFF"/>
    </Style>
    <Style Selector="Button.bannerGhost /template/ ContentPresenter">
        <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
    </Style>
    <Style Selector="Button.bannerGhost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#33FFFFFF"/>
        <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- Small inline text link (brand-coloured, no chrome) -->
    <Style Selector="Button.link">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BasisBrandBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.link /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisBrandBrush}"/>
    </Style>
    <Style Selector="Button.link:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisBrandHoverBrush}"/>
    </Style>

    <!-- Expander: a frosted-glass collapsible section that matches Border.card -->
    <Style Selector="Expander">
        <Setter Property="Background" Value="{StaticResource BasisGlassBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>
    <Style Selector="Expander /template/ ToggleButton#ExpanderHeader">
        <Setter Property="Padding" Value="20,14"/>
        <Setter Property="MinHeight" Value="0"/>
    </Style>
    <Style Selector="Expander /template/ Border#ExpanderContent">
        <Setter Property="Padding" Value="20,6,20,18"/>
    </Style>

    <!-- Flyout popup (the package "Manage" menu — the app's only flyout). The Fluent theme's
         default FlyoutPresenterBackground is translucent, and overriding Background on a bare-type
         style doesn't reliably beat the ControlTheme in 11.2.3, so the animated background bled
         through the menu. Leave the presenter chrome-less; an inner opaque Border built in
         PackagesView code-behind draws the panel, so the popup is reliably solid. -->
    <Style Selector="FlyoutPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MinWidth" Value="0"/>
    </Style>

    <!-- Menu-style buttons stacked inside a Flyout (the code-built Manage menu). -->
    <Style Selector="Button.menuItem">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <!-- Zero-alpha navy idle (not Transparent) so the hover fill fades in without the white wash. -->
        <Setter Property="Background" Value="#00221F44"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.menuItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisTextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.menuItem.destructive">
        <Setter Property="Foreground" Value="{StaticResource BasisBrandBrush}"/>
    </Style>
    <Style Selector="Button.menuItem.destructive:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BasisSurfaceHoverBrush}"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BasisBrandBrush}"/>
    </Style>

    <!-- Hover-lift for genuinely clickable cards/rows (package rows, install cards): a gentle rise +
         1% scale with a brighter fill/border on pointer-over, eased both ways. Applied via an opt-in
         class so static cards (hero, empty states) stay still. RenderTransform is animated through a
         TransformOperationsTransition — the transitions subsystem interpolates ITransform, unlike the
         keyframe Animation animator (see project_basispm_avalonia_animation_gotcha). -->
    <Style Selector="Border.interactive">
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="RenderTransform" Value="none"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.16" Easing="CubicEaseOut"/>
                <BrushTransition Property="Background" Duration="0:0:0.16"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.16"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.interactive:pointerover">
        <Setter Property="RenderTransform" Value="translateY(-2px) scale(1.01)"/>
        <Setter Property="Background" Value="{StaticResource BasisGlassStrongBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BasisBorderStrongBrush}"/>
    </Style>

    <!-- Soft fade-in for panels/overlays that toggle via IsVisible (update banner, clone form,
         install cards). Opacity has a built-in keyframe animator, so this is safe; it replays each
         time the element re-enters the visual tree. -->
    <Style Selector="Border.reveal">
        <Style.Animations>
            <Animation Duration="0:0:0.24" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
</Styles>
