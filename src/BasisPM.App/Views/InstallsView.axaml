<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             x:Class="BasisPM.App.Views.InstallsView"
             x:DataType="vm:InstallsViewModel"
             Name="Root">

    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="24">

            <Border CornerRadius="14" Padding="32,28" Background="{StaticResource BasisHeroGradient}"
                    BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="INSTALLS" Classes="tagline"/>
                        <TextBlock Text="Your Basis clones" Classes="h1"/>
                        <TextBlock Text="Clone the BasisVR/Basis repository, then manage its packages, updates and local changes."
                                   Classes="muted" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Content="Add existing" Command="{Binding AddExistingCommand}"/>
                        <Button Content="Clone Basis" Command="{Binding ToggleCloneFormCommand}"/>
                        <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="card" IsVisible="{Binding ShowCloneForm}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Clone Basis" Classes="h3"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Classes="versionPill">
                            <TextBlock Text="{Binding RepoUrl}" FontSize="11" Classes="brand"/>
                        </Border>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,8,Auto" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                            <TextBlock Text="Clone into folder" Classes="muted" FontSize="11"/>
                            <TextBox Text="{Binding ClonePath}" Watermark="C:\Users\you\BasisVR"/>
                        </StackPanel>
                        <Button Grid.Row="0" Grid.Column="2" Content="Browse…" VerticalAlignment="Bottom"
                                Command="{Binding BrowseCloneFolderCommand}"/>
                    </Grid>

                    <Border IsVisible="{Binding HasCloneSpaceWarning}"
                            Background="#1FF59E0B" BorderBrush="#66F59E0B" BorderThickness="1"
                            CornerRadius="8" Padding="12,9">
                        <StackPanel Orientation="Horizontal" Spacing="9">
                            <TextBlock Text="⚠" FontSize="15" Foreground="#F59E0B" VerticalAlignment="Top"/>
                            <TextBlock Text="{Binding CloneSpaceWarning}" TextWrapping="Wrap"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Sub-folder name" Classes="muted" FontSize="11"/>
                            <TextBox Text="{Binding FolderName}" Watermark="Basis"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="Branch" Classes="muted" FontSize="11"/>
                            <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}"
                                      HorizontalAlignment="Stretch" MaxDropDownHeight="320">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="vm:BranchOption">
                                        <TextBlock Text="{Binding Display}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button Classes="cta" Content="Clone Basis"
                                Command="{Binding CloneCommand}"
                                IsEnabled="{Binding IsNotCloning}"/>
                        <TextBlock Text="{Binding CloneProgress}" Classes="dim" FontSize="12"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   IsVisible="{Binding IsCloning}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding Installs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="12"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:InstallRow">
                        <Border Classes="card">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="5" ClipToBounds="True">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Classes="h3"/>
                                        <Border Classes="brandBadge" IsVisible="{Binding IsActive}">
                                            <TextBlock Text="ACTIVE" FontSize="10" FontWeight="Bold" Foreground="#FFFFFF"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding RepoRoot}" Classes="dim" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <Border Background="{StaticResource BasisPanelBrush}"
                                                BorderBrush="{StaticResource BasisBorderBrush}"
                                                BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="0,0,8,4">
                                            <TextBlock Text="{Binding UnityVersionLabel}" FontSize="11"
                                                       Foreground="{StaticResource BasisAccentBrush}"/>
                                        </Border>
                                        <Border Classes="versionPill" Margin="0,0,8,4">
                                            <TextBlock Text="{Binding BranchCommit}" FontSize="11" Classes="muted"
                                                       MaxWidth="300" TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding BranchCommit}"/>
                                        </Border>
                                        <Border Classes="versionPill" Margin="0,0,8,4" IsVisible="{Binding HasLocalChanges}">
                                            <TextBlock Text="{Binding ChangeCount, StringFormat='{}{0} changed'}"
                                                       FontSize="11" Classes="brand" FontWeight="Bold"/>
                                        </Border>
                                    </WrapPanel>
                                    <TextBlock Text="{Binding GitSummary}" Classes="muted" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button Content="Update Core" Classes="primary"
                                            Command="{Binding #Root.((vm:InstallsViewModel)DataContext).UpdateCoreCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Packages"
                                            Command="{Binding #Root.((vm:InstallsViewModel)DataContext).ManagePackagesCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Changes"
                                            Command="{Binding #Root.((vm:InstallsViewModel)DataContext).ViewChangesCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Open"
                                            Command="{Binding #Root.((vm:InstallsViewModel)DataContext).OpenFolderCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Backup" IsVisible="{Binding HasUnityProject}"
                                            Command="{Binding #Root.((vm:InstallsViewModel)DataContext).BackupCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="Zip Assets, Packages and ProjectSettings (not the Library cache)"/>
                                    <Button Content="Remove" Classes="danger"
                                            Command="{Binding #Root.((vm:InstallsViewModel)DataContext).RemoveCommand}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Classes="card" IsVisible="{Binding Installs.Count, Converter={x:Static vm:Converters.IntZero}}">
                <StackPanel Spacing="8" HorizontalAlignment="Center" Margin="0,40">
                    <TextBlock Text="No installs yet" Classes="h3" HorizontalAlignment="Center"/>
                    <TextBlock Text="Use Clone Basis above to pull down BasisVR/Basis, or Add existing to register a clone you already have."
                               Classes="muted" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="520" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
