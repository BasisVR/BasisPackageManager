<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             xmlns:loc="using:BasisPM.App.Localization"
             x:Class="BasisPM.App.Views.InstallsView"
             x:DataType="vm:InstallsViewModel"
             Name="Root">

    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="24">

            <Border CornerRadius="14" Padding="32,28" Background="{StaticResource BasisHeroGradient}"
                    BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="{loc:Tr installs.hero.tagline}" Classes="tagline"/>
                        <TextBlock Text="{loc:Tr installs.hero.title}" Classes="h1" TextWrapping="Wrap"/>
                        <TextBlock Text="{loc:Tr installs.hero.subtitle}"
                                   Classes="muted" FontSize="14" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Command="{Binding AddExistingCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconFolderOpen}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr installs.button.addExisting}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ToggleCloneFormCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconDownload}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr installs.button.cloneBasis}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="iconBtn" Command="{Binding RefreshCommand}" ToolTip.Tip="{loc:Tr installs.button.refresh}">
                            <PathIcon Width="16" Height="16" Data="{StaticResource IconRefresh}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="card reveal" IsVisible="{Binding ShowCloneForm}">
                <StackPanel Spacing="14">
                    <TextBlock Text="{loc:Tr installs.cloneForm.heading}" Classes="h3"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Classes="versionPill">
                            <TextBlock Text="{Binding RepoUrl}" FontSize="11" Classes="brand"/>
                        </Border>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,8,Auto" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                            <TextBlock Text="{loc:Tr installs.cloneForm.cloneIntoLabel}" Classes="muted" FontSize="11"/>
                            <TextBox Text="{Binding ClonePath}" Watermark="C:\Users\you\BasisVR"/>
                        </StackPanel>
                        <Button Grid.Row="0" Grid.Column="2" VerticalAlignment="Bottom"
                                Command="{Binding BrowseCloneFolderCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconFolderOpen}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr installs.button.browse}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border IsVisible="{Binding HasCloneSpaceWarning}"
                            Background="#1FF59E0B" BorderBrush="#66F59E0B" BorderThickness="1"
                            CornerRadius="8" Padding="12,9">
                        <StackPanel Orientation="Horizontal" Spacing="9">
                            <PathIcon Width="14" Height="14" Data="{StaticResource IconWarning}" Foreground="{StaticResource BasisWarningBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CloneSpaceWarning}" TextWrapping="Wrap"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="{loc:Tr installs.cloneForm.subFolderLabel}" Classes="muted" FontSize="11"/>
                            <TextBox Text="{Binding FolderName}" Watermark="Basis"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="{loc:Tr installs.cloneForm.branchLabel}" Classes="muted" FontSize="11"/>
                            <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}"
                                      HorizontalAlignment="Stretch" MaxDropDownHeight="320">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="vm:BranchOption">
                                        <TextBlock Text="{Binding Display}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button Classes="cta"
                                Command="{Binding CloneCommand}"
                                IsEnabled="{Binding IsNotCloning}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconDownload}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr installs.button.cloneBasis}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding CloneProgress}" Classes="dim" FontSize="12"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   IsVisible="{Binding IsCloning}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding Installs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="12"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:InstallRow">
                        <Border Classes="card reveal">
                            <StackPanel Spacing="14">
                                <StackPanel Spacing="5">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Classes="h3"/>
                                        <Border Classes="brandBadge" IsVisible="{Binding IsActive}">
                                            <TextBlock Text="{loc:Tr installs.badge.active}" FontSize="10" FontWeight="Bold" Foreground="#FFFFFF"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding RepoRoot}" Classes="dim" FontSize="12"
                                               TextWrapping="Wrap" ToolTip.Tip="{Binding RepoRoot}"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <Border Background="{StaticResource BasisPanelBrush}"
                                                BorderBrush="{StaticResource BasisBorderBrush}"
                                                BorderThickness="1" CornerRadius="4" Padding="8,2" Margin="0,0,8,4">
                                            <TextBlock Text="{Binding UnityVersionLabel}" FontSize="11"
                                                       Foreground="{StaticResource BasisAccentBrush}"/>
                                        </Border>
                                        <Border Classes="versionPill" Margin="0,0,8,4">
                                            <TextBlock Text="{Binding BranchCommit}" FontSize="11" Classes="muted"
                                                       MaxWidth="300" TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding BranchCommit}"/>
                                        </Border>
                                        <Border Classes="versionPill" Margin="0,0,8,4" IsVisible="{Binding HasLocalChanges}">
                                            <TextBlock Text="{Binding ChangeCount, StringFormat='{}{0} changed'}"
                                                       FontSize="11" Classes="brand" FontWeight="Bold"/>
                                        </Border>
                                    </WrapPanel>
                                    <TextBlock Text="{Binding GitSummary}" Classes="muted" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <WrapPanel>
                                    <WrapPanel.Styles>
                                        <Style Selector="Button"><Setter Property="Margin" Value="0,0,8,8"/></Style>
                                    </WrapPanel.Styles>
                                    <Button Classes="primary" IsVisible="{Binding HasUnityProject}"
                                            Command="{Binding #Root.((vm:InstallsViewModel)DataContext).OpenInUnityCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconPlay}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{loc:Tr develop.button.openInUnity}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Classes.primary="{Binding CoreHasUpdate}"
                                            Command="{Binding #Root.((vm:InstallsViewModel)DataContext).UpdateCoreCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{Binding GitSummary}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconUpdate}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{loc:Tr installs.button.updateCore}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button IsVisible="{Binding IsGitRepo}"
                                            Command="{Binding #Root.((vm:InstallsViewModel)DataContext).ChangeBranchCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{loc:Tr installs.tooltip.changeBranch}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconBranch}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{loc:Tr installs.button.changeBranch}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding #Root.((vm:InstallsViewModel)DataContext).ManagePackagesCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconPackages}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{loc:Tr installs.button.packages}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding #Root.((vm:InstallsViewModel)DataContext).ViewChangesCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconChanges}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{loc:Tr installs.button.changes}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button IsVisible="{Binding HasUnityProject}"
                                            Command="{Binding #Root.((vm:InstallsViewModel)DataContext).BackupCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{loc:Tr installs.tooltip.backup}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconArchive}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{loc:Tr installs.button.backup}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="iconBtn danger"
                                            Command="{Binding #Root.((vm:InstallsViewModel)DataContext).RemoveCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{loc:Tr installs.button.remove}">
                                        <PathIcon Width="16" Height="16" Data="{StaticResource IconDelete}"/>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Classes="card" IsVisible="{Binding Installs.Count, Converter={x:Static vm:Converters.IntZero}}">
                <StackPanel Spacing="8" HorizontalAlignment="Center" Margin="0,40">
                    <TextBlock Text="{loc:Tr installs.empty.title}" Classes="h3" HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr installs.empty.body}"
                               Classes="muted" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="520" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
