<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:BasisPM.App.Localization"
        x:Class="BasisPM.App.Views.SubmitPrWindow"
        Title="{loc:Tr dialog.submitPr.title}"
        Width="500" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BasisBackgroundBrush}">
    <StackPanel Margin="26" Spacing="14">
        <TextBlock Text="{loc:Tr dialog.submitPr.title}" Classes="h3"/>
        <TextBlock x:Name="SubText" Classes="dim" FontSize="12" TextWrapping="Wrap"/>
        <StackPanel Spacing="6">
            <TextBlock Text="{loc:Tr dialog.submitPr.titleLabel}" Classes="muted" FontSize="11"/>
            <TextBox x:Name="TitleBox" Watermark="{loc:Tr dialog.submitPr.titleWatermark}"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="{loc:Tr dialog.submitPr.descriptionLabel}" Classes="muted" FontSize="11"/>
            <TextBox x:Name="BodyBox" AcceptsReturn="True" Height="96" TextWrapping="Wrap"
                     Watermark="{loc:Tr dialog.submitPr.descriptionWatermark}"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="{loc:Tr dialog.submitPr.branchLabel}" Classes="muted" FontSize="11"/>
            <TextBox x:Name="BranchBox"/>
        </StackPanel>
        <TextBlock Text="{loc:Tr dialog.submitPr.hint}"
                   Classes="dim" FontSize="11" TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="{loc:Tr dialog.submitPr.cancel}" Click="OnCancel"/>
            <Button Classes="primary" Content="{loc:Tr dialog.submitPr.openPr}" Click="OnOk"/>
        </StackPanel>
    </StackPanel>
</Window>
