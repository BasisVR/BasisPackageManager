<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:BasisPM.App.Localization"
        x:Class="BasisPM.App.Views.RoleWizardWindow"
        Title="{loc:Tr dialog.roleWizard.title}"
        Width="560" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BasisBackgroundBrush}">
    <StackPanel Margin="30" Spacing="18">
        <StackPanel Spacing="6">
            <TextBlock Text="{loc:Tr dialog.roleWizard.welcome}" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="{loc:Tr dialog.roleWizard.intro}"
                       Classes="muted" FontSize="13" TextWrapping="Wrap"/>
        </StackPanel>

        <Button Click="OnUser" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="18,16">
            <Grid ColumnDefinitions="Auto,*">
                <PathIcon Grid.Column="0" Width="24" Height="24" Data="{StaticResource IconPerson}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{loc:Tr dialog.roleWizard.userTitle}" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock Text="{loc:Tr dialog.roleWizard.userDesc}"
                               Classes="muted" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Button>

        <Button Click="OnDeveloper" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="18,16">
            <Grid ColumnDefinitions="Auto,*">
                <PathIcon Grid.Column="0" Width="24" Height="24" Data="{StaticResource IconDevelop}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{loc:Tr dialog.roleWizard.developerTitle}" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock Text="{loc:Tr dialog.roleWizard.developerDesc}"
                               Classes="muted" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Button>
    </StackPanel>
</Window>
