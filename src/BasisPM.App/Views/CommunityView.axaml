<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             xmlns:loc="using:BasisPM.App.Localization"
             x:Class="BasisPM.App.Views.CommunityView"
             x:DataType="vm:CommunityViewModel">

    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="18">

            <!-- Hero -->
            <Border CornerRadius="14" Padding="32,28"
                    Background="{StaticResource BasisHeroGradient}"
                    BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="{loc:Tr community.hero.tagline}" Classes="tagline"/>
                    <TextBlock Text="{loc:Tr community.hero.title}" Classes="h1"/>
                    <TextBlock Text="{loc:Tr community.hero.subtitle}"
                               Classes="muted" FontSize="14" TextWrapping="Wrap" MaxWidth="660" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                        <Button Classes="primary" Command="{Binding Documentation.DocsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconBook}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr community.button.openDocs}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding Documentation.DiscordCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconChat}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr community.button.joinDiscord}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Announcements ───────────────────────────────── -->
            <Grid ColumnDefinitions="*,Auto" Margin="4,6,0,0">
                <TextBlock Grid.Column="0" Text="{loc:Tr community.announcements.heading}" Classes="h2" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Classes="iconBtn" Command="{Binding Announcements.RefreshCommand}" ToolTip.Tip="{loc:Tr community.button.refresh}">
                    <PathIcon Width="16" Height="16" Data="{StaticResource IconRefresh}"/>
                </Button>
            </Grid>
            <TextBlock Text="{loc:Tr community.announcements.loading}" Classes="dim" FontSize="12"
                       IsVisible="{Binding Announcements.IsLoading}"/>
            <ItemsControl ItemsSource="{Binding Announcements.Announcements}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="14"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:AnnouncementCard">
                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <Border CornerRadius="999" Padding="10,3" Background="{Binding LevelBrush}">
                                        <TextBlock Text="{Binding LevelLabel}" FontSize="10"
                                                   FontWeight="Bold" Foreground="#FFFFFF"/>
                                    </Border>
                                    <Border Classes="versionPill" IsVisible="{Binding IsPinned}">
                                        <TextBlock Text="{loc:Tr community.announcements.pinned}" FontSize="10" FontWeight="Bold" Classes="muted"/>
                                    </Border>
                                    <TextBlock Text="{Binding DateDisplay}" Classes="dim" FontSize="12"
                                               VerticalAlignment="Center" IsVisible="{Binding HasDate}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Title}" Classes="h3" FontSize="17"/>
                                <TextBlock Text="{Binding Body}" Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                                <Button Content="{Binding LinkText}" HorizontalAlignment="Left"
                                        IsVisible="{Binding HasLink}"
                                        Command="{Binding OpenLinkCommand}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Border Classes="card" IsVisible="{Binding Announcements.ShowEmpty}">
                <StackPanel Spacing="8" HorizontalAlignment="Center" Margin="0,24">
                    <TextBlock Text="{loc:Tr community.announcements.emptyTitle}" Classes="h3" HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr community.announcements.emptyBody}"
                               Classes="muted" HorizontalAlignment="Center" TextAlignment="Center"
                               MaxWidth="480" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ── Documentation ───────────────────────────────── -->
            <TextBlock Text="{loc:Tr community.docs.heading}" Classes="h2" Margin="4,10,0,0"/>
            <Grid ColumnDefinitions="*,*">
                <Border Grid.Column="0" Classes="card" Margin="0,0,10,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:Tr community.docs.siteTitle}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr community.docs.siteBody}"
                                   Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                        <Button Command="{Binding Documentation.DocsCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconOpenExternal}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr community.docs.openSite}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Margin="10,0,0,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:Tr community.docs.askTitle}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr community.docs.askBody}"
                                   Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                        <Button Command="{Binding Documentation.DiscordCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconChat}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr community.button.joinDiscord}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{loc:Tr community.docs.sourceTitle}" Classes="h3"/>
                    <TextBlock Text="{loc:Tr community.docs.sourceBody}"
                               Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Command="{Binding Documentation.BasisRepoCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconOpenExternal}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr community.docs.basisRepo}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding Documentation.PackageManagerRepoCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconOpenExternal}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr community.docs.pmRepo}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Support ─────────────────────────────────────── -->
            <TextBlock Text="{loc:Tr community.support.heading}" Classes="h2" Margin="4,10,0,0"/>
            <TextBlock Text="{loc:Tr community.support.intro}"
                       Classes="muted" FontSize="13" TextWrapping="Wrap" MaxWidth="680" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Classes="primary" Command="{Binding Support.OpenCollectiveCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconHeart}" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr community.support.openCollective}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding Support.DiscordCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconChat}" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr community.button.joinDiscord}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <Grid ColumnDefinitions="*,*">
                <Border Grid.Column="0" Classes="card" Margin="0,0,10,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:Tr community.support.donationsTitle}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr community.support.donationsBody}"
                                   Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                        <Button Command="{Binding Support.OpenCollectiveCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconHeart}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr community.support.backOpenCollective}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Margin="10,0,0,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:Tr community.support.collabTitle}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr community.support.collabBody}"
                                   Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                        <Button Command="{Binding Support.FundingPageCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconStar}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr community.support.sponsorFeature}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{loc:Tr community.support.moneyTitle}" Classes="h3"/>
                    <TextBlock Text="{loc:Tr community.support.moneyBody}"
                               Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                    <Button Command="{Binding Support.FundingPageCommand}" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconOpenExternal}" VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Tr community.support.fundingPage}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
