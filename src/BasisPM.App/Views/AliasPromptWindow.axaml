<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:BasisPM.App.Localization"
        x:Class="BasisPM.App.Views.AliasPromptWindow"
        Title="{loc:Tr dialog.alias.title}"
        Width="460" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BasisBackgroundBrush}">
    <StackPanel Margin="26" Spacing="14">
        <TextBlock x:Name="TitleText" Text="{loc:Tr dialog.alias.title}" Classes="h3"/>
        <TextBlock x:Name="PathText" Classes="dim" FontSize="12" TextWrapping="Wrap"/>
        <StackPanel Spacing="6">
            <TextBlock Text="{loc:Tr dialog.alias.displayName}" Classes="muted" FontSize="11"/>
            <TextBox x:Name="Input" Watermark="{loc:Tr dialog.alias.watermark}" ToolTip.Tip="{loc:Tr dialog.alias.tooltip.input}"/>
        </StackPanel>
        <TextBlock Text="{loc:Tr dialog.alias.hint}" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Click="OnCancel" ToolTip.Tip="{loc:Tr dialog.alias.tooltip.cancel}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconClose}" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr dialog.alias.cancel}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Classes="primary" Click="OnOk" ToolTip.Tip="{loc:Tr dialog.alias.tooltip.save}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconSave}" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr dialog.alias.save}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
