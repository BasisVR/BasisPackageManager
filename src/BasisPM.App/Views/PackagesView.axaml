<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             xmlns:models="using:BasisPM.Core.Models"
             x:Class="BasisPM.App.Views.PackagesView"
             x:DataType="vm:PackagesViewModel"
             Name="Root">

    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="20">

            <Border CornerRadius="14" Padding="32,24"
                    Background="{StaticResource BasisHeroGradient}"
                    BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="PACKAGES" Classes="tagline"/>
                        <TextBlock Text="{Binding InstallName}" Classes="h1"/>
                        <TextBlock Text="Curated Basis packages, any community UPM repo, or NuGet packages that work with Basis."
                                   Classes="muted" FontSize="14"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshCommand}"/>
                </Grid>
            </Border>

            <Border Classes="card" IsVisible="{Binding !HasInstall}">
                <StackPanel Spacing="10" HorizontalAlignment="Center" Margin="0,50">
                    <TextBlock Text="No install with a Unity project" Classes="h3" HorizontalAlignment="Center"/>
                    <TextBlock Text="Clone or select a Basis install on the Installs tab to manage its packages."
                               Classes="muted" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Spacing="20" IsVisible="{Binding HasInstall}">

                <!-- Curated catalog -->
                <Border Classes="card" Padding="0">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <Border Grid.Row="0" Padding="20,16" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="Curated" Classes="h3" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Classes="brandBadge" HorizontalAlignment="Left" Margin="10,0,0,0">
                                    <TextBlock Text="VERIFIED" FontSize="10" FontWeight="Bold" Foreground="#FFFFFF"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Padding="20,12" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <TextBox Watermark="Filter curated packages..." Text="{Binding Filter}"/>
                        </Border>
                        <ScrollViewer Grid.Row="2" MaxHeight="300">
                            <ItemsControl ItemsSource="{Binding Available}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:PackageRow">
                                        <Border Padding="20,14" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                <StackPanel Grid.Column="0" Spacing="3">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Name}" Classes="dim" FontSize="11"/>
                                                    <TextBlock Text="{Binding Description}" Classes="muted" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <Border Classes="versionPill">
                                                        <TextBlock Text="{Binding Version}" FontSize="11" Classes="brand"/>
                                                    </Border>
                                                    <Button Content="{Binding ButtonLabel}" Classes="primary"
                                                            Command="{Binding #Root.((vm:PackagesViewModel)DataContext).InstallCommand}"
                                                            CommandParameter="{Binding Entry}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Community from GitHub -->
                <Border Classes="card" Padding="20,16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Add community package from GitHub" Classes="h3"/>
                        <TextBlock Classes="muted" FontSize="11" TextWrapping="Wrap"
                                   Text="Paste a GitHub URL, or owner/repo[?path=Sub/Folder][#branch]. Its package.json is added to your Unity manifest as a git dependency."/>
                        <Grid ColumnDefinitions="*,8,Auto">
                            <TextBox Grid.Column="0" Text="{Binding GitHubInput}"
                                     Watermark="https://github.com/owner/repo  or  owner/repo?path=Packages/com.x#main"/>
                            <Button Grid.Column="2" Classes="primary" Content="+ Add" Command="{Binding AddFromGitHubCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- NuGet -->
                <Border Classes="card" Padding="0">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <Border Grid.Row="0" Padding="20,16" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="NuGet packages" Classes="h3"/>
                        </Border>
                        <Border Grid.Row="1" Padding="20,12" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,8,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding NuGetQuery}" Watermark="Search NuGet.org (e.g. Newtonsoft.Json)"/>
                                    <Button Grid.Column="2" Classes="primary" Content="Search" Command="{Binding SearchNuGetCommand}"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*">
                                    <CheckBox Grid.Column="0" Content="Include prerelease" IsChecked="{Binding IncludePrerelease}"/>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Classes="dim" FontSize="11"
                                               Text="Added to Assets/packages.config — restore in Unity with NuGetForUnity."/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="2" MaxHeight="300">
                            <ItemsControl ItemsSource="{Binding NuGetResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:NuGetResultRow">
                                        <Border Padding="20,14" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                <StackPanel Grid.Column="0" Spacing="3">
                                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Id}" FontWeight="SemiBold"/>
                                                        <Border Classes="versionPill" IsVisible="{Binding Verified}">
                                                            <TextBlock Text="verified" FontSize="10" Classes="brand" FontWeight="Bold"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding AuthorLine}" Classes="dim" FontSize="11"/>
                                                    <TextBlock Text="{Binding Description}" Classes="muted" FontSize="12" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding DownloadsLabel}" Classes="dim" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <Border Classes="versionPill">
                                                        <TextBlock Text="{Binding Version}" FontSize="11" Classes="brand"/>
                                                    </Border>
                                                    <Button Content="{Binding ButtonLabel}" Classes="primary"
                                                            Command="{Binding #Root.((vm:PackagesViewModel)DataContext).InstallNuGetCommand}"
                                                            CommandParameter="{Binding Package}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Installed -->
                <Border Classes="card" Padding="0">
                    <StackPanel>
                        <Border Padding="20,16" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Installed — UPM manifest" Classes="h3"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding Installed}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:InstalledPackageRow">
                                    <Border Padding="20,12" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <StackPanel Grid.Column="0" Spacing="3">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                    <Border Classes="versionPill" IsVisible="{Binding IsFromGit}">
                                                        <TextBlock Text="github" FontSize="10" Classes="brand" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Version}" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Remove" Classes="danger"
                                                    Command="{Binding #Root.((vm:PackagesViewModel)DataContext).UninstallCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Padding="20,16" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,1,0,1">
                            <TextBlock Text="Installed — NuGet (packages.config)" Classes="h3"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding InstalledNuGet}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:NuGetInstalled">
                                    <Border Padding="20,12" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding Id}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Version}" Classes="dim" FontSize="11"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Remove" Classes="danger"
                                                    Command="{Binding #Root.((vm:PackagesViewModel)DataContext).RemoveNuGetCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
