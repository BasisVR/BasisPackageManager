<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             xmlns:models="using:BasisPM.Core.Models"
             x:Class="BasisPM.App.Views.PackagesView"
             x:DataType="vm:PackagesViewModel"
             Name="Root">

    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="20">

            <Border CornerRadius="14" Padding="32,24"
                    Background="{StaticResource BasisHeroGradient}"
                    BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="PACKAGES" Classes="tagline"/>
                        <TextBlock Text="Packages" Classes="h1"/>
                        <TextBlock Text="Pick a project, then install packages from the Basis registry or add any community UPM package by git URL."
                                   Classes="muted" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <StackPanel Spacing="4" IsVisible="{Binding HasInstalls}">
                            <TextBlock Text="Project" Classes="muted" FontSize="11"/>
                            <ComboBox MinWidth="200" MaxDropDownHeight="360"
                                      ItemsSource="{Binding InstallOptions}" SelectedItem="{Binding SelectedInstall}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="models:BasisInstall">
                                        <StackPanel Spacing="-1">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding UnityVersion, StringFormat='Unity {0}'}" Classes="dim" FontSize="10"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <Button Content="Create bundle" Command="{Binding CreateBundleCommand}" VerticalAlignment="Bottom" IsVisible="{Binding HasInstall}"/>
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="card" IsVisible="{Binding !HasInstall}">
                <StackPanel Spacing="10" HorizontalAlignment="Center" Margin="0,50">
                    <TextBlock Text="No install with a Unity project" Classes="h3" HorizontalAlignment="Center"/>
                    <TextBlock Text="Clone or select a Basis install on the Installs tab to manage its packages."
                               Classes="muted" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Spacing="20" IsVisible="{Binding HasInstall}">

                <!-- Available to install (Basis registry / basisvr.org/packages) -->
                <Border Classes="card" Padding="0">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <Border Grid.Row="0" Padding="20,16" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="Available to install" Classes="h3" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Classes="brandBadge" HorizontalAlignment="Left" Margin="10,0,0,0">
                                    <TextBlock Text="BASIS REGISTRY" FontSize="10" FontWeight="Bold" Foreground="#FFFFFF"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Padding="20,12" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <TextBox Watermark="Filter packages..." Text="{Binding Filter}"/>
                        </Border>
                        <ScrollViewer Grid.Row="2" MaxHeight="320">
                            <ItemsControl ItemsSource="{Binding Available}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:PackageRow">
                                        <Border Background="{StaticResource BasisSurfaceMutedBrush}"
                                                BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1"
                                                CornerRadius="12" Padding="14" Margin="16,7">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Width="46" Height="46" CornerRadius="13" VerticalAlignment="Top"
                                                        Background="{StaticResource BasisBrandGradient}">
                                                    <TextBlock Text="{Binding Initial}" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="14,0,12,0" Spacing="2" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                                        <Border Background="{StaticResource BasisSurfaceHoverBrush}" CornerRadius="999" Padding="8,2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Owner}" FontSize="10" FontWeight="Bold" Classes="muted"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Name}" Classes="dim" FontSize="11"/>
                                                    <TextBlock Text="{Binding Description}" Classes="muted" FontSize="12" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding Author, StringFormat='by {0}'}" Classes="dim" FontSize="11" IsVisible="{Binding HasAuthor}"/>
                                                        <TextBlock Text="{Binding Unity, StringFormat='Unity {0}'}" Classes="dim" FontSize="11" IsVisible="{Binding HasUnity}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <Border Classes="versionPill" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding Version}" FontSize="11" Classes="brand"/>
                                                    </Border>
                                                    <Button Content="{Binding ButtonLabel}" Classes="primary" MinWidth="90"
                                                            Command="{Binding #Root.((vm:PackagesViewModel)DataContext).InstallCommand}"
                                                            CommandParameter="{Binding Entry}"/>
                                                    <Button Content="Choose version…" MinWidth="90" FontSize="11" Padding="10,6"
                                                            IsVisible="{Binding HasGit}"
                                                            ToolTip.Tip="Pick a specific release, beta, or the default branch"
                                                            Command="{Binding #Root.((vm:PackagesViewModel)DataContext).ChooseVersionCommand}"
                                                            CommandParameter="{Binding Entry}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Community from GitHub -->
                <Border Classes="card" Padding="20,16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Add community package from GitHub" Classes="h3"/>
                        <TextBlock Classes="muted" FontSize="11" TextWrapping="Wrap"
                                   Text="Paste a GitHub URL, or owner/repo[?path=Sub/Folder][#branch]. Its package.json is added to your Unity manifest as a git dependency."/>
                        <Grid ColumnDefinitions="*,8,Auto">
                            <TextBox Grid.Column="0" Text="{Binding GitHubInput}"
                                     Watermark="https://github.com/owner/repo  or  owner/repo?path=Packages/com.x#main"/>
                            <Button Grid.Column="2" Classes="primary" Content="+ Add" Command="{Binding AddFromGitHubCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Installed (a collapsible tab, closed until opened) -->
                <Expander IsExpanded="False" HorizontalAlignment="Stretch">
                    <Expander.Header>
                        <TextBlock Text="Installed" Classes="h3"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <Border Padding="0,0,0,10" Margin="0,0,0,4" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <ComboBox HorizontalAlignment="Left" MinWidth="150"
                                      ItemsSource="{Binding InstalledOwners}"
                                      SelectedItem="{Binding SelectedInstalledOwner}"
                                      ToolTip.Tip="Filter installed packages by owner (from the package id)"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding Installed}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:InstalledPackageRow">
                                    <Border Padding="20,12" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <StackPanel Grid.Column="0" Spacing="3">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                    <Border Classes="versionPill" IsVisible="{Binding IsFromGit}">
                                                        <TextBlock Text="github" FontSize="10" Classes="brand" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Version}" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Remove" Classes="danger"
                                                    Command="{Binding #Root.((vm:PackagesViewModel)DataContext).UninstallCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
