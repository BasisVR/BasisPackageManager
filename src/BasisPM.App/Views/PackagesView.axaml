<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             xmlns:models="using:BasisPM.Core.Models"
             xmlns:loc="using:BasisPM.App.Localization"
             x:Class="BasisPM.App.Views.PackagesView"
             x:DataType="vm:PackagesViewModel"
             Name="Root">

    <UserControl.Resources>
        <!-- One shared per-row action block (Install when not installed, else the Manage menu),
             referenced by BOTH the list and grid item templates so there is a single definition. -->
        <DataTemplate x:Key="PackageActions" DataType="vm:PackageRow">
            <StackPanel Spacing="8">
                <Button Classes="primary" HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsAvailableToInstall}"
                        Command="{Binding #Root.((vm:PackagesViewModel)DataContext).InstallCommand}"
                        CommandParameter="{Binding Entry}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconDownload}" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr packages.button.install}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="secondary" HorizontalAlignment="Stretch"
                        IsVisible="{Binding IsManageable}" Click="OnManageClick">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconSettings}" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr packages.button.manage}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- Mounted for editing: it's the local Packages/ folder, not the registry git URL —
                     so neither "install" nor "manage" applies. -->
                <Border IsVisible="{Binding IsMounted}" HorizontalAlignment="Stretch"
                        Background="#263B82F6" BorderBrush="#803B82F6" BorderThickness="1" CornerRadius="10" Padding="10,7"
                        ToolTip.Tip="{Binding MountedHint}">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <PathIcon Width="15" Height="15" Data="{StaticResource IconEdit}" Foreground="{StaticResource BasisBlueBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding MountedStateLabel}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BasisBlueBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- One Source/Category filter chip (label + count), highlighted when it's the active pick.
             Shared by the Source and Category chip rows; the VM routes the click by chip.Kind. -->
        <DataTemplate x:Key="FacetChip" DataType="vm:FacetChip">
            <Button Classes="chip" Classes.selected="{Binding IsSelected}"
                    Command="{Binding #Root.((vm:PackagesViewModel)DataContext).SelectFacetCommand}"
                    CommandParameter="{Binding}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Count}" Opacity="0.55" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Detail overlay entrance: fade the scrim and scale the card up, both eased. The hidden
             state also turns hit-testing off so the transparent scrim never blocks the list beneath.
             Opacity (DoubleTransition) and RenderTransform (TransformOperationsTransition) both have
             transition interpolators, so this is safe (see project_basispm_avalonia_animation_gotcha). -->
        <Style Selector="Border.detailOverlay">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.16" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.detailOverlay.shown">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
        </Style>
        <Style Selector="Border.detailCard">
            <Setter Property="RenderTransform" Value="scale(0.96)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.detailOverlay.shown Border.detailCard">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>

        <!-- Filter chips (Source / Category). The selected chip fills with the brand gradient. -->
        <Style Selector="Button.chip">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Background" Value="{StaticResource BasisSurfaceHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BasisBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.chip.selected">
            <Setter Property="Background" Value="{StaticResource BasisBrandGradient}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <Grid>
    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="20">

            <Border CornerRadius="14" Padding="32,24"
                    Background="{StaticResource BasisHeroGradient}"
                    BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="{loc:Tr packages.hero.tagline}" Classes="tagline"/>
                        <TextBlock Text="{loc:Tr packages.hero.title}" Classes="h1" TextWrapping="Wrap"/>
                        <TextBlock Text="{loc:Tr packages.hero.subtitle}"
                                   Classes="muted" FontSize="14" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <StackPanel Spacing="4" IsVisible="{Binding HasInstalls}">
                            <TextBlock Text="{loc:Tr packages.label.project}" Classes="muted" FontSize="11"/>
                            <ComboBox MinWidth="200" MaxDropDownHeight="360"
                                      ItemsSource="{Binding InstallOptions}" SelectedItem="{Binding SelectedInstall}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="models:BasisInstall">
                                        <StackPanel Spacing="-1">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding UnityVersion, StringFormat='Unity {0}'}" Classes="dim" FontSize="10"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <Button Command="{Binding CreatePackageListCommand}" VerticalAlignment="Bottom" IsVisible="{Binding HasInstall}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconPackages}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr packages.button.createPackageList}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="iconBtn" Command="{Binding InstallPackageListFromFileCommand}" VerticalAlignment="Bottom"
                                IsVisible="{Binding HasInstalls}"
                                ToolTip.Tip="{loc:Tr packages.button.installPackageListFile}">
                            <PathIcon Width="16" Height="16" Data="{StaticResource IconFolderOpen}"/>
                        </Button>
                        <Button Classes="iconBtn" Command="{Binding RefreshCommand}" VerticalAlignment="Bottom"
                                ToolTip.Tip="{loc:Tr packages.button.refresh}">
                            <PathIcon Width="16" Height="16" Data="{StaticResource IconRefresh}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="card" IsVisible="{Binding !HasInstall}">
                <StackPanel Spacing="10" HorizontalAlignment="Center" Margin="0,50">
                    <TextBlock Text="{loc:Tr packages.empty.noProjectTitle}" Classes="h3" HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr packages.empty.noProjectDescription}"
                               Classes="muted" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Spacing="20" IsVisible="{Binding HasInstall}">

                <!-- Git preflight: mounting and PRs shell out to git, so nudge the user to install it. -->
                <Border Classes="card" Padding="16,12" IsVisible="{Binding GitMissing}"
                        Background="#26F59E0B" BorderBrush="#80F59E0B">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Margin="0,0,12,0" Text="{loc:Tr develop.git.requiredDescription}"
                                   Classes="muted" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Classes="primary" Command="{Binding InstallGitCommand}" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconDownload}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr develop.button.installGit}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Available to install (Basis registry / basisvr.org/packages) -->
                <Border Classes="card" Padding="0">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <Border Grid.Row="0" Padding="20,16" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="{Binding ListHeaderLabel}" Classes="h3" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Classes="brandBadge" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center"
                                        IsVisible="{Binding !ShowInstalledOnly}">
                                    <TextBlock Text="{loc:Tr packages.badge.basisRegistry}" FontSize="10" FontWeight="Bold" Foreground="#FFFFFF"/>
                                </Border>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button Content="{Binding InstalledToggleLabel}" Command="{Binding ToggleInstalledCommand}"
                                            FontSize="12" Padding="14,7"
                                            ToolTip.Tip="{loc:Tr packages.tooltip.showInstalled}"/>
                                    <Button Content="{Binding LayoutToggleLabel}" Command="{Binding ToggleLayoutCommand}"
                                            FontSize="12" Padding="14,7"
                                            ToolTip.Tip="{loc:Tr packages.tooltip.toggleLayout}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Padding="20,12" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Spacing="12">
                                <!-- Search + sort, mirroring the website's top bar. -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Watermark="{loc:Tr packages.filter.watermark}" Text="{Binding Filter}"/>
                                    <ComboBox Grid.Column="1" Margin="10,0,0,0" MinWidth="170" VerticalAlignment="Center"
                                              ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}"
                                              ToolTip.Tip="{loc:Tr packages.filter.sortBy}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SortOption">
                                                <TextBlock Text="{Binding Label}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                                <!-- Source facet chips (All / Official / Community / …), each with a count. -->
                                <ItemsControl ItemsSource="{Binding SourceFacets}" ItemTemplate="{StaticResource FacetChip}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <!-- Category facet chips; shown only when the catalog carries categories. -->
                                <ItemsControl ItemsSource="{Binding CategoryFacets}" ItemTemplate="{StaticResource FacetChip}"
                                              IsVisible="{Binding HasCategoryFacets}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <!-- List layout: one roomy row per package, with a wide action column. -->
                        <ScrollViewer Grid.Row="2" MaxHeight="720" IsVisible="{Binding IsListView}">
                            <ItemsControl ItemsSource="{Binding Available}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:PackageRow">
                                        <Border Classes="glass interactive" Classes.edited="{Binding IsChanged}" Padding="14" Margin="16,7" Cursor="Hand" Tapped="OnRowTapped"
                                                ToolTip.Tip="{loc:Tr packages.tooltip.viewDetails}">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Width="46" Height="46" CornerRadius="13" VerticalAlignment="Top"
                                                        Background="{StaticResource BasisBrandGradient}">
                                                    <TextBlock Text="{Binding TileGlyph}" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="14,0,16,0" Spacing="3" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                                        <Border Background="{StaticResource BasisSurfaceHoverBrush}" CornerRadius="999" Padding="8,2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Owner}" FontSize="10" FontWeight="Bold" Classes="muted"/>
                                                        </Border>
                                                        <Border Classes="unofficialBadge" VerticalAlignment="Center" IsVisible="{Binding IsUnofficial}">
                                                            <TextBlock Text="{loc:Tr packages.badge.unofficial}" FontSize="9" FontWeight="Bold"
                                                                       Foreground="{StaticResource BasisWarningBrush}"/>
                                                        </Border>
                                                        <Border VerticalAlignment="Center" IsVisible="{Binding IsMounted}"
                                                                Background="#263B82F6" BorderBrush="#803B82F6" BorderThickness="1" CornerRadius="999" Padding="8,2">
                                                            <TextBlock Text="{loc:Tr packages.badge.mounted}" FontSize="9" FontWeight="Bold"
                                                                       Foreground="{StaticResource BasisBlueBrush}"/>
                                                        </Border>
                                                        <!-- License sits with the name/description (identity), not down with the version/branch pills. -->
                                                        <Border Classes="versionPill" VerticalAlignment="Center" IsVisible="{Binding HasLicense}"
                                                                ToolTip.Tip="{loc:Tr packages.label.license}">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <PathIcon Width="11" Height="11" Data="{StaticResource IconLicense}" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding License}" FontSize="11" Classes="muted" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Name}" Classes="dim" FontSize="11"/>
                                                    <TextBlock Text="{Binding Description}" Classes="muted" FontSize="12" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                                    <WrapPanel Margin="0,4,0,0">
                                                        <WrapPanel.Styles>
                                                            <Style Selector="WrapPanel > Border, WrapPanel > TextBlock, WrapPanel > Button">
                                                                <Setter Property="Margin" Value="0,0,8,4"/>
                                                            </Style>
                                                        </WrapPanel.Styles>
                                                        <!-- One status pill: the installed branch/version (green) when installed,
                                                             else a greyed "Not Installed". No separate available-version pill. -->
                                                        <Border Classes="versionPill" VerticalAlignment="Center" IsVisible="{Binding IsAvailableToInstall}"
                                                                Background="#12FFFFFF" BorderBrush="#26FFFFFF">
                                                            <TextBlock Text="{loc:Tr packages.state.notInstalled}" FontSize="11" Classes="dim"/>
                                                        </Border>
                                                        <Border Classes="versionPill" VerticalAlignment="Center" IsVisible="{Binding HasInstalledVersion}"
                                                                Background="#2622C55E" BorderBrush="#8022C55E" ToolTip.Tip="{Binding InstalledVersionText}">
                                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                                <PathIcon Width="11" Height="11" Data="{StaticResource IconBranch}" Foreground="{StaticResource BasisSuccessBrush}" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding InstalledLabel}" FontSize="11" Foreground="{StaticResource BasisSuccessBrush}" VerticalAlignment="Center" MaxWidth="180" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Text="{Binding Author, StringFormat='by {0}'}" Classes="dim" FontSize="11" VerticalAlignment="Center" IsVisible="{Binding HasAuthor}"/>
                                                        <TextBlock Text="{Binding Unity, StringFormat='Unity {0}'}" Classes="dim" FontSize="11" VerticalAlignment="Center" IsVisible="{Binding HasUnity}"/>
                                                        <Border Classes="versionPill" VerticalAlignment="Center" IsVisible="{Binding HasCategory}">
                                                            <TextBlock Text="{Binding Category}" FontSize="11" Classes="muted"/>
                                                        </Border>
                                                        <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center" IsVisible="{Binding HasStars}">
                                                            <TextBlock Text="★" FontSize="11" Classes="dim" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding StarsText}" FontSize="11" Classes="dim" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Button Classes="link" VerticalAlignment="Center" IsVisible="{Binding HasLink}"
                                                                ToolTip.Tip="{Binding Link}"
                                                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).OpenLinkCommand}"
                                                                CommandParameter="{Binding Link}">
                                                            <PathIcon Width="14" Height="14" Data="{StaticResource IconOpenExternal}"/>
                                                        </Button>
                                                    </WrapPanel>
                                                </StackPanel>
                                                <ContentControl Grid.Column="2" Width="160" VerticalAlignment="Center"
                                                                Content="{Binding}" ContentTemplate="{StaticResource PackageActions}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Grid layout: cards that wrap; toggled from the header. -->
                        <ScrollViewer Grid.Row="2" MaxHeight="840" IsVisible="{Binding IsGridView}">
                            <ItemsControl ItemsSource="{Binding Available}" Margin="10,7">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:PackageRow">
                                        <Border Classes="glass interactive" Classes.edited="{Binding IsChanged}" Padding="16" Margin="6" Width="234" Cursor="Hand" Tapped="OnRowTapped"
                                                ToolTip.Tip="{loc:Tr packages.tooltip.viewDetails}">
                                            <StackPanel Spacing="10">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Border Width="40" Height="40" CornerRadius="11" Background="{StaticResource BasisBrandGradient}">
                                                        <TextBlock Text="{Binding TileGlyph}" FontSize="19" FontWeight="Bold" Foreground="#FFFFFF"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center" Spacing="1">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                                        <TextBlock Text="{Binding Owner}" Classes="dim" FontSize="10"/>
                                                        <Border Classes="unofficialBadge" HorizontalAlignment="Left" Margin="0,2,0,0" IsVisible="{Binding IsUnofficial}">
                                                            <TextBlock Text="{loc:Tr packages.badge.unofficial}" FontSize="9" FontWeight="Bold"
                                                                       Foreground="{StaticResource BasisWarningBrush}"/>
                                                        </Border>
                                                        <Border HorizontalAlignment="Left" Margin="0,2,0,0" IsVisible="{Binding IsMounted}"
                                                                Background="#263B82F6" BorderBrush="#803B82F6" BorderThickness="1" CornerRadius="999" Padding="8,2">
                                                            <TextBlock Text="{loc:Tr packages.badge.mounted}" FontSize="9" FontWeight="Bold"
                                                                       Foreground="{StaticResource BasisBlueBrush}"/>
                                                        </Border>
                                                        <Border Classes="versionPill" HorizontalAlignment="Left" Margin="0,2,0,0" IsVisible="{Binding HasLicense}"
                                                                ToolTip.Tip="{Binding License}">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <PathIcon Width="10" Height="10" Data="{StaticResource IconLicense}" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding License}" FontSize="10" Classes="muted" VerticalAlignment="Center"
                                                                           MaxWidth="110" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" Classes="muted" FontSize="11" TextWrapping="Wrap"
                                                           MaxLines="3" TextTrimming="CharacterEllipsis" Height="50"/>
                                                <WrapPanel>
                                                    <WrapPanel.Styles>
                                                        <Style Selector="WrapPanel > Border, WrapPanel > Button">
                                                            <Setter Property="Margin" Value="0,0,6,4"/>
                                                        </Style>
                                                    </WrapPanel.Styles>
                                                    <Border Classes="versionPill" VerticalAlignment="Center" IsVisible="{Binding IsAvailableToInstall}"
                                                            Background="#12FFFFFF" BorderBrush="#26FFFFFF">
                                                        <TextBlock Text="{loc:Tr packages.state.notInstalled}" FontSize="10" Classes="dim"/>
                                                    </Border>
                                                    <Border Classes="versionPill" VerticalAlignment="Center" IsVisible="{Binding HasInstalledVersion}"
                                                            Background="#2622C55E" BorderBrush="#8022C55E" ToolTip.Tip="{Binding InstalledVersionText}">
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <PathIcon Width="10" Height="10" Data="{StaticResource IconBranch}" Foreground="{StaticResource BasisSuccessBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding InstalledLabel}" FontSize="10" Foreground="{StaticResource BasisSuccessBrush}" VerticalAlignment="Center" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Classes="versionPill" VerticalAlignment="Center" IsVisible="{Binding HasCategory}">
                                                        <TextBlock Text="{Binding Category}" FontSize="10" Classes="muted"/>
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center" IsVisible="{Binding HasStars}">
                                                        <TextBlock Text="★" FontSize="10" Classes="dim" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding StarsText}" FontSize="10" Classes="dim" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Button Classes="link" VerticalAlignment="Center" IsVisible="{Binding HasLink}"
                                                            ToolTip.Tip="{Binding Link}"
                                                            Command="{Binding #Root.((vm:PackagesViewModel)DataContext).OpenLinkCommand}"
                                                            CommandParameter="{Binding Link}">
                                                        <PathIcon Width="14" Height="14" Data="{StaticResource IconOpenExternal}"/>
                                                    </Button>
                                                </WrapPanel>
                                                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource PackageActions}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock Grid.Row="2" Text="{loc:Tr packages.installed.empty}" Classes="muted"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,44"
                                   IsVisible="{Binding ShowInstalledEmptyHint}"/>
                    </Grid>
                </Border>

                <!-- Community from GitHub -->
                <Border Classes="card" Padding="20,16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:Tr packages.header.community}" Classes="h3"/>
                        <TextBlock Classes="muted" FontSize="11" TextWrapping="Wrap"
                                   Text="{loc:Tr packages.community.description}"/>
                        <Grid ColumnDefinitions="*,8,Auto">
                            <TextBox Grid.Column="0" Text="{Binding GitHubInput}"
                                     Watermark="{loc:Tr packages.community.watermark}"/>
                            <Button Grid.Column="2" Classes="primary" Command="{Binding AddFromGitHubCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconAdd}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Tr packages.button.add}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>

    <!-- Package detail overlay — opened by clicking a package row, closed by ✕ or the backdrop.
         Kept in the tree and driven by the `shown` class (bound to ShowDetail) so the scrim can fade
         and the card can scale in/out; the hidden state disables hit-testing so the invisible scrim
         never eats clicks meant for the list. -->
    <Border Classes="detailOverlay" Classes.shown="{Binding ShowDetail}"
            Background="#E6000000" Tapped="OnBackdropTapped">
        <!-- Opaque surface (overriding the translucent card glass) so the detail text stays readable
             over the animated background; the card glass is fine on the static list but not here. -->
        <Border Classes="card detailCard" Background="{StaticResource BasisSurfaceBrush}"
                MaxWidth="620" MaxHeight="740" Margin="40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                RenderTransformOrigin="50%,50%">
            <ScrollViewer DataContext="{Binding SelectedPackage}">
                <StackPanel Spacing="16" x:DataType="vm:PackageRow">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" Width="56" Height="56" CornerRadius="15" VerticalAlignment="Top"
                                Background="{StaticResource BasisBrandGradient}">
                            <TextBlock Text="{Binding TileGlyph}" FontSize="26" FontWeight="Bold" Foreground="#FFFFFF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" Classes="h2"/>
                            <TextBlock Text="{Binding Name}" Classes="dim" FontSize="12"/>
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,3,0,0">
                                <TextBlock Text="{Binding Author, StringFormat='by {0}'}" Classes="muted" FontSize="12" IsVisible="{Binding HasAuthor}"/>
                                <TextBlock Text="{Binding Owner}" Classes="dim" FontSize="12"/>
                                <Border Classes="unofficialBadge" VerticalAlignment="Center" IsVisible="{Binding IsUnofficial}">
                                    <TextBlock Text="{loc:Tr packages.badge.unofficial}" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource BasisWarningBrush}"/>
                                </Border>
                                <Border VerticalAlignment="Center" IsVisible="{Binding IsMounted}"
                                        Background="#263B82F6" BorderBrush="#803B82F6" BorderThickness="1" CornerRadius="999" Padding="8,2">
                                    <TextBlock Text="{loc:Tr packages.badge.mounted}" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource BasisBlueBrush}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="2" Classes="iconBtn" VerticalAlignment="Top"
                                ToolTip.Tip="{loc:Tr packages.detail.close}"
                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).CloseDetailCommand}">
                            <PathIcon Width="15" Height="15" Data="{StaticResource IconClose}"/>
                        </Button>
                    </Grid>

                    <TextBlock Text="{Binding Description}" Classes="muted" FontSize="13" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Classes="versionPill"><TextBlock Text="{Binding Version, StringFormat='v{0}'}" FontSize="11" Classes="brand"/></Border>
                        <Border Classes="versionPill" IsVisible="{Binding HasInstalledVersion}"
                                Background="#2622C55E" BorderBrush="#8022C55E" ToolTip.Tip="{Binding InstalledVersionText}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <PathIcon Width="11" Height="11" Data="{StaticResource IconBranch}" Foreground="{StaticResource BasisSuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding InstalledLabel}" FontSize="11" Foreground="{StaticResource BasisSuccessBrush}" VerticalAlignment="Center" MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="versionPill" IsVisible="{Binding HasLicense}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Width="11" Height="11" Data="{StaticResource IconLicense}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding License}" FontSize="11" Classes="muted" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="versionPill" IsVisible="{Binding HasUnity}"><TextBlock Text="{Binding Unity, StringFormat='Unity {0}'}" FontSize="11" Classes="muted"/></Border>
                        <Border Classes="versionPill" IsVisible="{Binding HasCategory}"><TextBlock Text="{Binding Category}" FontSize="11" Classes="muted"/></Border>
                    </StackPanel>

                    <StackPanel Spacing="6" IsVisible="{Binding HasDependencies}">
                        <TextBlock Text="{loc:Tr packages.detail.dependencies}" Classes="dim" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="{Binding DependencySummary}" Classes="muted" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Spacing="6" IsVisible="{Binding HasGitUrl}">
                        <TextBlock Text="{loc:Tr packages.detail.gitUrl}" Classes="dim" FontSize="11" FontWeight="Bold"/>
                        <Border Classes="glass" Padding="10,8" CornerRadius="8">
                            <TextBlock Text="{Binding GitUrl}" FontFamily="{StaticResource MonoFontFamily}" FontSize="11" Classes="muted" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <!-- Locally mounted for editing: it's the local Packages/ folder, not the registry
                             git URL. The label flips to "Local edits" once the working clone is dirty. -->
                        <Border IsVisible="{Binding IsMounted}"
                                Background="#263B82F6" BorderBrush="#803B82F6" BorderThickness="1" CornerRadius="10" Padding="12,10">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Width="16" Height="16" Data="{StaticResource IconEdit}" Foreground="{StaticResource BasisBlueBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding MountedStateLabel}" FontWeight="SemiBold" Foreground="{StaticResource BasisBlueBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding MountFolder}" Classes="dim" FontSize="11" TextWrapping="Wrap" IsVisible="{Binding HasMountFolder}"/>
                            </StackPanel>
                        </Border>
                        <Button Classes="primary" HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsAvailableToInstall}"
                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).InstallCommand}"
                                CommandParameter="{Binding Entry}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconDownload}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr packages.button.install}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="primary" HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsManageable}"
                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).InstallCommand}"
                                CommandParameter="{Binding Entry}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconUpdate}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr packages.button.update}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button HorizontalAlignment="Stretch"
                                IsVisible="{Binding CanChooseVersion}"
                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).ChooseVersionCommand}"
                                CommandParameter="{Binding Entry}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconTag}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr packages.button.chooseVersion}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Mount to edit: clone this git package into the project and swap the manifest to it. -->
                        <Button HorizontalAlignment="Stretch"
                                IsVisible="{Binding CanMountToEdit}"
                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).MountCommand}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconEdit}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr develop.button.mountToEdit}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Mounted-package actions: open the folder, submit a PR, or swap back to the registry. -->
                        <Button HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsMounted}"
                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).OpenFolderCommand}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconFolderOpen}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr packages.button.openFolder}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="primary" HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsMounted}"
                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).SubmitPrCommand}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconBranch}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr develop.button.submitPr}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsMounted}"
                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).SwapBackCommand}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconUndo}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr develop.button.swapBack}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Accidental edits made directly in Library/PackageCache → turn them into a PR. -->
                        <Button Classes="primary" HorizontalAlignment="Stretch"
                                IsVisible="{Binding HasDrift}"
                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).ReviewDriftCommand}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconBranch}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr packages.button.reviewDrift}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="danger" HorizontalAlignment="Stretch"
                                IsVisible="{Binding IsManageable}"
                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).RemoveCommand}"
                                CommandParameter="{Binding Entry}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconDelete}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr packages.button.remove}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="link" HorizontalAlignment="Center" Margin="0,4,0,0"
                                IsVisible="{Binding HasLink}"
                                Command="{Binding #Root.((vm:PackagesViewModel)DataContext).OpenLinkCommand}"
                                CommandParameter="{Binding Link}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Width="13" Height="13" Data="{StaticResource IconOpenExternal}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr packages.detail.website}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Border>
    </Grid>
</UserControl>
