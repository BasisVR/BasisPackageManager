<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:BasisPM.App.Views"
        xmlns:loc="using:BasisPM.App.Localization"
        x:Class="BasisPM.App.Views.CreatePackageListWindow"
        Title="{loc:Tr dialog.createPackageList.title}"
        Width="520" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BasisBackgroundBrush}">
    <DockPanel Margin="26,24">
        <StackPanel DockPanel.Dock="Top" Spacing="12">
            <TextBlock Text="{loc:Tr dialog.createPackageList.heading}" Classes="h3"/>
            <TextBlock Text="{loc:Tr dialog.createPackageList.intro}"
                       Classes="muted" FontSize="12" TextWrapping="Wrap"/>
            <StackPanel Spacing="4">
                <TextBlock Text="{loc:Tr dialog.createPackageList.nameLabel}" Classes="muted" FontSize="11"/>
                <TextBox x:Name="NameBox" ToolTip.Tip="{loc:Tr dialog.createPackageList.tooltip.name}"/>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="{loc:Tr dialog.createPackageList.descriptionLabel}" Classes="muted" FontSize="11"/>
                <TextBox x:Name="DescBox" AcceptsReturn="True" Height="58" TextWrapping="Wrap" ToolTip.Tip="{loc:Tr dialog.createPackageList.tooltip.description}"/>
            </StackPanel>
            <TextBlock x:Name="BasisLine" Classes="dim" FontSize="11"/>
            <TextBlock Text="{loc:Tr dialog.createPackageList.packagesLabel}" Classes="muted" FontSize="11" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Spacing="10" Margin="0,14,0,0">
            <TextBlock x:Name="ErrorText" Foreground="#FFE06B6B" FontSize="12" IsVisible="False" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Click="OnCancel" ToolTip.Tip="{loc:Tr dialog.createPackageList.tooltip.cancel}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconClose}" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr dialog.createPackageList.cancel}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="OnSubmit" ToolTip.Tip="{loc:Tr dialog.createPackageList.tooltip.create}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconOpenExternal}" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr dialog.createPackageList.create}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="primary" Click="OnSaveLocal" ToolTip.Tip="{loc:Tr dialog.createPackageList.tooltip.saveLocal}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconSave}" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr dialog.createPackageList.saveLocal}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <Border Classes="card" Padding="0" Margin="0,8,0,0">
            <ScrollViewer>
                <ItemsControl x:Name="PackagesItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:PackagePick">
                            <Border Padding="14,8" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                                <CheckBox IsChecked="{Binding Include}" ToolTip.Tip="{loc:Tr dialog.createPackageList.tooltip.include}">
                                    <StackPanel Spacing="-1">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Subtitle}" Classes="dim" FontSize="10"/>
                                    </StackPanel>
                                </CheckBox>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
