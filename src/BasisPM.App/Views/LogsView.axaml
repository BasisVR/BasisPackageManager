<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             xmlns:loc="using:BasisPM.App.Localization"
             x:Class="BasisPM.App.Views.LogsView"
             x:DataType="vm:LogsViewModel"
             Name="Root">
    <Grid Margin="40,32" RowDefinitions="Auto,*">
        <Border Grid.Row="0" CornerRadius="14" Padding="32,24" Background="{StaticResource BasisHeroGradient}"
                BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="{loc:Tr logs.hero.tagline}" Classes="tagline"/>
                    <TextBlock Text="{loc:Tr logs.hero.title}" Classes="h1"/>
                    <TextBlock Text="{loc:Tr logs.hero.subtitle}"
                               Classes="muted" FontSize="14" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                    <Button Classes="iconBtn" Click="OnCopy" ToolTip.Tip="{loc:Tr logs.button.copy}">
                        <PathIcon Width="16" Height="16" Data="{StaticResource IconCopy}"/>
                    </Button>
                    <Button Classes="iconBtn" Command="{Binding OpenFolderCommand}" ToolTip.Tip="{loc:Tr logs.button.openFolder}">
                        <PathIcon Width="16" Height="16" Data="{StaticResource IconFolderOpen}"/>
                    </Button>
                    <Button Classes="iconBtn" Command="{Binding ClearCommand}" ToolTip.Tip="{loc:Tr logs.button.clear}">
                        <PathIcon Width="16" Height="16" Data="{StaticResource IconDelete}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="card" Margin="0,20,0,0" Padding="0">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Entries}" Margin="8,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:LogRow">
                            <Grid ColumnDefinitions="Auto,*" Margin="12,2">
                                <TextBlock Grid.Column="0" Text="{Binding Time}" Classes="dim"
                                           FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Message}" Foreground="{Binding Brush}"
                                           FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
