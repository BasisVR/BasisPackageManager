<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             xmlns:loc="using:BasisPM.App.Localization"
             x:Class="BasisPM.App.Views.FundingView"
             x:DataType="vm:FundingViewModel">

    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="20">

            <Border CornerRadius="14" Padding="32,28"
                    Background="{StaticResource BasisHeroGradient}"
                    BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="{loc:Tr support.hero.tagline}" Classes="tagline"/>
                    <TextBlock Text="{loc:Tr support.hero.title}" Classes="h1"/>
                    <TextBlock Text="{loc:Tr support.hero.subtitle}"
                               Classes="muted" FontSize="14" TextWrapping="Wrap" MaxWidth="660" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                        <Button Classes="primary" Command="{Binding OpenCollectiveCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconHeart}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr support.button.openCollective}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DiscordCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconChat}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr support.button.joinDiscord}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*">
                <Border Grid.Column="0" Classes="card" Margin="0,0,10,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:Tr support.community.title}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr support.community.body}"
                                   Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                        <TextBlock Text="{loc:Tr support.community.bullets}"
                                   Classes="dim" FontSize="12"/>
                        <Button Command="{Binding OpenCollectiveCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconHeart}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr support.button.backOpenCollective}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Margin="10,0,0,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:Tr support.company.title}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr support.company.body}"
                                   Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                        <TextBlock Text="{loc:Tr support.company.bullets}"
                                   Classes="dim" FontSize="12"/>
                        <Button Command="{Binding FundingPageCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconStar}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr support.button.sponsorFeature}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{loc:Tr support.where.title}" Classes="h3"/>
                    <TextBlock Text="{loc:Tr support.where.body}"
                               Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                    <Button Command="{Binding FundingPageCommand}" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconOpenExternal}" VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Tr support.button.fullFundingPage}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
