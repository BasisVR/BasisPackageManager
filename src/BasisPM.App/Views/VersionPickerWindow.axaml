<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:BasisPM.Core.Models"
        x:Class="BasisPM.App.Views.VersionPickerWindow"
        Title="Choose a version"
        Width="560" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BasisBackgroundBrush}">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="26">
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" Text="Choose a version" Classes="h3"/>
            <TextBlock x:Name="SubText" Classes="dim" FontSize="12" TextWrapping="Wrap"/>
        </StackPanel>
        <CheckBox Grid.Row="1" x:Name="ShowPre" Content="Show prereleases (betas)" Margin="0,0,0,10" Click="OnShowPreChanged"/>
        <Border Grid.Row="2" Classes="card" Padding="4">
            <ListBox x:Name="List" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="models:PackageVersionOption">
                        <Grid ColumnDefinitions="*,Auto" Margin="10,9">
                            <StackPanel Grid.Column="0" Spacing="1">
                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Kind}" Classes="dim" FontSize="10"/>
                            </StackPanel>
                            <Border Grid.Column="1" Classes="versionPill" VerticalAlignment="Center" IsVisible="{Binding IsPrerelease}">
                                <TextBlock Text="beta" FontSize="10" FontWeight="Bold" Classes="brand"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,14,0,0">
            <Button Content="Cancel" Click="OnCancel"/>
            <Button Classes="primary" Content="Install this version" Click="OnOk"/>
        </StackPanel>
    </Grid>
</Window>
