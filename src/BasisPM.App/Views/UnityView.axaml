<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             xmlns:models="using:BasisPM.Core.Models"
             xmlns:loc="using:BasisPM.App.Localization"
             x:Class="BasisPM.App.Views.UnityView"
             x:DataType="vm:UnityViewModel"
             Name="Root">

    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="24">

            <Border CornerRadius="14" Padding="32,28" Background="{StaticResource BasisHeroGradient}"
                    BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="{loc:Tr unity.header.tagline}" Classes="tagline"/>
                        <TextBlock Text="{loc:Tr unity.header.title}" Classes="h1" TextWrapping="Wrap"/>
                        <TextBlock Text="{loc:Tr unity.header.subtitle}"
                                   Classes="muted" FontSize="14" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Classes="iconBtn" Command="{Binding RefreshCommand}" ToolTip.Tip="{loc:Tr unity.button.refresh}">
                        <PathIcon Width="16" Height="16" Data="{StaticResource IconRefresh}"/>
                    </Button>
                </Grid>
            </Border>

            <Border Classes="card" Padding="20,16">
                <TextBlock Text="{Binding HubStatus}" Classes="muted" TextWrapping="Wrap"/>
            </Border>

            <Border CornerRadius="12" Padding="20,14" Background="{StaticResource BasisSurfaceHoverBrush}"
                    BorderBrush="{StaticResource BasisBrandBrush}" BorderThickness="1"
                    IsVisible="{Binding HasRequiredVersion}">
                <TextBlock Text="{Binding RequiredVersionNote}" Foreground="{StaticResource BasisTextPrimaryBrush}" TextWrapping="Wrap"/>
            </Border>

            <Expander IsExpanded="True" HorizontalAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="{loc:Tr unity.section.installedEditors}" Classes="h3"/>
                </Expander.Header>
                <StackPanel Spacing="12" Margin="0,10,0,0">
                    <ComboBox ItemsSource="{Binding InstalledEditors}"
                              SelectedItem="{Binding SelectedEditor}"
                              HorizontalAlignment="Stretch" MaxDropDownHeight="320"
                              IsVisible="{Binding HasInstalledEditors}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="models:InstalledEditor">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Version}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{loc:Tr unity.tag.manual}" Classes="dim" FontSize="11"
                                               VerticalAlignment="Center" IsVisible="{Binding IsManual}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center" IsVisible="{Binding HasSelectedEditor}">
                        <TextBlock Grid.Column="0" Text="{Binding SelectedEditor.Path}" Classes="dim" FontSize="11"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                        <Button Grid.Column="1" Classes="iconBtn"
                                IsVisible="{Binding SelectedEditorIsManual}"
                                Command="{Binding RemoveEditorCommand}" CommandParameter="{Binding SelectedEditor}"
                                ToolTip.Tip="{loc:Tr unity.button.removeEditor}">
                            <PathIcon Width="16" Height="16" Data="{StaticResource IconClose}"/>
                        </Button>
                    </Grid>
                    <StackPanel Spacing="10" IsVisible="{Binding SelectedEditorIsHub}">
                        <TextBlock Text="{loc:Tr unity.editors.modulesHint}" Classes="muted" FontSize="12" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding EditorModuleOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ModuleOption">
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding Selected}" Margin="0,0,16,8"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Classes="secondary" Command="{Binding InstallModulesCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconDownload}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr unity.button.installModules}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{loc:Tr unity.editors.none}" Classes="muted" FontSize="12"
                               IsVisible="{Binding !HasInstalledEditors}"/>
                    <TextBlock Text="{loc:Tr unity.editors.addHint}" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
                    <Button Classes="secondary" Command="{Binding AddEditorCommand}" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconFolderOpen}" VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Tr unity.button.addFromFolder}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Expander>

            <Expander IsExpanded="False" HorizontalAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="{loc:Tr unity.section.installNew}" Classes="h3"/>
                </Expander.Header>
                <StackPanel Spacing="14" Margin="0,10,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="muted" FontSize="12" TextWrapping="Wrap"
                                   VerticalAlignment="Center" Text="{loc:Tr unity.install.hint}"/>
                        <Button Grid.Column="1" Classes="iconBtn" VerticalAlignment="Top" Margin="12,0,0,0"
                                Command="{Binding ReloadReleasesCommand}" ToolTip.Tip="{loc:Tr unity.button.reloadList}">
                            <PathIcon Width="16" Height="16" Data="{StaticResource IconRefresh}"/>
                        </Button>
                    </Grid>

                    <Grid ColumnDefinitions="*,16,200" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="6">
                            <TextBlock Text="{loc:Tr unity.label.release}" Classes="muted" FontSize="11"/>
                            <ComboBox ItemsSource="{Binding AvailableReleases}"
                                      SelectedItem="{Binding SelectedRelease}"
                                      HorizontalAlignment="Stretch"
                                      MaxDropDownHeight="320">
                                <ComboBox.Styles>
                                    <Style Selector="ComboBoxItem" x:DataType="vm:UnityReleaseRow">
                                        <Setter Property="IsEnabled" Value="{Binding !IsInstalled}"/>
                                    </Style>
                                </ComboBox.Styles>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="vm:UnityReleaseRow">
                                        <StackPanel Orientation="Horizontal" Spacing="10"
                                                    Opacity="{Binding IsInstalled, Converter={x:Static vm:Converters.InstalledOpacity}}">
                                            <TextBlock Text="{Binding Release.Version}" FontWeight="SemiBold" MinWidth="120"/>
                                            <TextBlock Text="{Binding Release.Stream}" Classes="muted" MinWidth="80"/>
                                            <TextBlock Text="{loc:Tr unity.tag.recommended}" Foreground="{StaticResource BasisAccentBrush}"
                                                       FontSize="11" IsVisible="{Binding Release.Recommended}"/>
                                            <TextBlock Text="{loc:Tr unity.tag.installed}" Classes="dim" FontSize="11" IsVisible="{Binding IsInstalled}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="0" Spacing="6">
                            <TextBlock Text="{loc:Tr unity.label.streamFilter}" Classes="muted" FontSize="11"/>
                            <ComboBox ItemsSource="{Binding StreamFilters}"
                                      SelectedItem="{Binding StreamFilter}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4" IsVisible="{Binding SelectedRelease, Converter={x:Static vm:Converters.NotNull}}">
                        <TextBlock Text="{loc:Tr unity.label.changeset}" Classes="muted" FontSize="11"/>
                        <TextBlock Text="{Binding SelectedRelease.Release.ShortRevision}" Classes="dim" FontSize="12"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding ModuleOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ModuleOption">
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding Selected}" Margin="0,0,16,8"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Classes="primary" Command="{Binding InstallCommand}" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconDownload}" VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Tr unity.button.install}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
