<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BasisPM.App.ViewModels"
        x:Class="BasisPM.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Basis Package Manager"
        Icon="/Assets/BasisLogo.png"
        Width="1240" Height="820"
        MinWidth="1000" MinHeight="660"
        Background="{StaticResource BasisBackgroundBrush}">

    <Panel ClipToBounds="True">
        <Border Opacity="0.14">
            <Border.Background>
                <LinearGradientBrush StartPoint="100%,0%" EndPoint="0%,100%">
                    <GradientStop Offset="0" Color="#EF1237"/>
                    <GradientStop Offset="0.33" Color="#9333EA"/>
                    <GradientStop Offset="0.66" Color="#3B82F6"/>
                    <GradientStop Offset="1" Color="#F43F5E"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Canvas IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="260" Height="260" Canvas.Left="-60" Canvas.Top="-40"
                     Fill="#26EF1237">
                <Ellipse.Effect>
                    <BlurEffect Radius="120"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="320" Height="320" Canvas.Right="-80" Canvas.Top="60"
                     Fill="#269333EA">
                <Ellipse.Effect>
                    <BlurEffect Radius="140"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="220" Height="220" Canvas.Left="280" Canvas.Bottom="-40"
                     Fill="#1F3B82F6">
                <Ellipse.Effect>
                    <BlurEffect Radius="120"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="200" Height="200" Canvas.Right="120" Canvas.Bottom="-30"
                     Fill="#26F43F5E">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid ColumnDefinitions="220,*" RowDefinitions="*,Auto">

            <Grid Grid.Column="0" Grid.Row="0" RowDefinitions="Auto,*,Auto">
                <StackPanel Grid.Row="0" Margin="22,28,22,32" Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="9"
                                ClipToBounds="True"
                                BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                            <Image Source="/Assets/BasisLogo.png" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Spacing="-2">
                            <TextBlock Text="BasisVR" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="Package Manager" FontSize="11" Classes="muted"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="0" Margin="10,0">
                    <Button Classes="nav" Classes.active="{Binding IsInstalls}" Tag="installs" Click="OnNavClick">Installs</Button>
                    <Grid>
                        <Button Classes="nav" Classes.active="{Binding IsAnnouncements}" Tag="announcements" Click="OnNavClick" HorizontalAlignment="Stretch">Announcements</Button>
                        <Border Classes="brandBadge" Padding="7,1" MinWidth="18"
                                HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0"
                                IsHitTestVisible="False"
                                IsVisible="{Binding HasUnreadAnnouncements}">
                            <TextBlock Text="{Binding AnnouncementsUnreadCount}"
                                       FontSize="10" FontWeight="Bold" Foreground="#FFFFFF"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <Button Classes="nav" Classes.active="{Binding IsSupport}" Tag="support" Click="OnNavClick">Support</Button>
                    <Button Classes="nav" Classes.active="{Binding IsDocumentation}" Tag="documentation" Click="OnNavClick">Documentation</Button>
                    <Button Classes="nav" Classes.active="{Binding IsPackages}" Tag="packages" Click="OnNavClick">Packages</Button>
                    <Button Classes="nav" Classes.active="{Binding IsDevelop}" Tag="develop" Click="OnNavClick" IsVisible="{Binding ShowDevelopTab}">Develop</Button>
                    <Button Classes="nav" Classes.active="{Binding IsChanges}" Tag="changes" Click="OnNavClick" IsVisible="{Binding ShowChangesTab}">Local Changes</Button>
                    <Button Classes="nav" Classes.active="{Binding IsUnity}" Tag="unity" Click="OnNavClick">Unity Editors</Button>
                    <Button Classes="nav" Classes.active="{Binding IsSettings}" Tag="settings" Click="OnNavClick">Settings</Button>
                    <Button Classes="nav" Classes.active="{Binding IsLogs}" Tag="logs" Click="OnNavClick">Logs</Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="22,0,22,22" Spacing="6">
                    <Rectangle Height="1" Fill="{StaticResource BasisBorderBrush}" Margin="0,0,0,12"/>
                    <Border Classes="versionPill" HorizontalAlignment="Left" Margin="0,0,0,4"
                            ToolTip.Tip="Installed version — check for updates in Settings">
                        <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}" FontSize="12" FontWeight="SemiBold" Classes="brand"/>
                    </Border>
                    <TextBlock Text="basisvr.org" Classes="dim" FontSize="11"/>
                    <TextBlock Text="MIT licensed" Classes="dim" FontSize="11"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1" Grid.Row="0" RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        IsVisible="{Binding UpdateAvailable}"
                        Background="{StaticResource BasisBrandGradient}"
                        CornerRadius="12"
                        Padding="18,12" Margin="18,16,18,0">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UpdateBannerText}"
                                       Foreground="#FFFFFF" FontWeight="SemiBold" FontSize="13"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                            <ProgressBar IsVisible="{Binding IsUpdating}"
                                         Minimum="0" Maximum="100" Value="{Binding UpdateProgress}"
                                         ShowProgressText="True"
                                         Foreground="#FFFFFF" Background="#33FFFFFF"
                                         Height="16" CornerRadius="8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                    Margin="16,0,0,0" VerticalAlignment="Center"
                                    IsVisible="{Binding !IsUpdating}">
                            <Button Classes="bannerPrimary" Content="Update now"
                                    Command="{Binding InstallUpdateCommand}"
                                    ToolTip.Tip="Download the update and restart"/>
                            <Button Classes="bannerGhost" Content="Later"
                                    Command="{Binding DismissUpdateCommand}"
                                    ToolTip.Tip="Dismiss until next launch"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
            </Grid>

            <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                    Background="#A0100F27"
                    BorderBrush="{StaticResource BasisBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="18,9">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusMessage}"
                               Classes="muted"
                               Classes.statusError="{Binding IsStatusError}"
                               Classes.statusSuccess="{Binding IsStatusSuccess}"
                               FontSize="12" FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="12,0,0,0"
                                IsVisible="{Binding CanCopyStatus}">
                        <Button Content="Copy" Padding="10,4" FontSize="11"
                                Click="OnCopyStatusClick"
                                ToolTip.Tip="Copy status message to clipboard"/>
                        <Button Content="Open an issue" Padding="10,4" FontSize="11"
                                IsVisible="{Binding IsStatusError}"
                                Command="{Binding OpenIssueCommand}"
                                ToolTip.Tip="Open a pre-filled GitHub issue with this error and your last actions"/>
                        <Button Content="OK" Padding="10,4" FontSize="11"
                                Click="OnDismissStatusClick"
                                ToolTip.Tip="Dismiss this message"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Panel>
</Window>
