<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BasisPM.App.ViewModels"
        xmlns:loc="using:BasisPM.App.Localization"
        x:Class="BasisPM.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{loc:Tr shell.window.title}"
        Icon="/Assets/BasisLogo.png"
        Width="1240" Height="820"
        MinWidth="1000" MinHeight="660"
        Background="{StaticResource BasisBackgroundBrush}">

    <Panel ClipToBounds="True">
        <!-- Animated background: an oversized brand gradient that slowly pans on a loop
             (mirrors the website's .animated-gradient background-position sweep), plus
             colored blobs that drift on independent loops. -->
        <Panel.Styles>
            <!-- Pans the oversized gradient horizontally so its diagonal color bands sweep
                 across, the desktop equivalent of the site's `background-position: 0%->100%`
                 shift. 7.5s each way = 15s round trip, matching the site's `15s` keyframe.
                 Canvas.Left is a double (built-in animator); RenderTransform has none and
                 throws at load — see project_basispm_avalonia_animation_gotcha. -->
            <Style Selector="Border.flowGradient">
                <Style.Animations>
                    <Animation Duration="0:0:7.5" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                        <KeyFrame Cue="0%"><Setter Property="Canvas.Left" Value="0"/></KeyFrame>
                        <KeyFrame Cue="100%"><Setter Property="Canvas.Left" Value="-480"/></KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
            <!-- Blobs drift by animating their Canvas anchors (double → built-in animator).
                 RenderTransform has no default animator in Avalonia and throws at load. -->
            <Style Selector="Ellipse.blobA">
                <Style.Animations>
                    <Animation Duration="0:0:23" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                        <KeyFrame Cue="0%"><Setter Property="Canvas.Left" Value="-60"/><Setter Property="Canvas.Top" Value="-40"/></KeyFrame>
                        <KeyFrame Cue="100%"><Setter Property="Canvas.Left" Value="20"/><Setter Property="Canvas.Top" Value="30"/></KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
            <Style Selector="Ellipse.blobB">
                <Style.Animations>
                    <Animation Duration="0:0:29" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                        <KeyFrame Cue="0%"><Setter Property="Canvas.Right" Value="-80"/><Setter Property="Canvas.Top" Value="60"/></KeyFrame>
                        <KeyFrame Cue="100%"><Setter Property="Canvas.Right" Value="-10"/><Setter Property="Canvas.Top" Value="115"/></KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
            <Style Selector="Ellipse.blobC">
                <Style.Animations>
                    <Animation Duration="0:0:34" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                        <KeyFrame Cue="0%"><Setter Property="Canvas.Left" Value="280"/><Setter Property="Canvas.Bottom" Value="-40"/></KeyFrame>
                        <KeyFrame Cue="100%"><Setter Property="Canvas.Left" Value="210"/><Setter Property="Canvas.Bottom" Value="20"/></KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
            <Style Selector="Ellipse.blobD">
                <Style.Animations>
                    <Animation Duration="0:0:26" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                        <KeyFrame Cue="0%"><Setter Property="Canvas.Right" Value="120"/><Setter Property="Canvas.Bottom" Value="-30"/></KeyFrame>
                        <KeyFrame Cue="100%"><Setter Property="Canvas.Right" Value="55"/><Setter Property="Canvas.Bottom" Value="30"/></KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Panel.Styles>

        <!-- Flowing gradient backdrop: an oversized -45deg gradient (start bottom-right ->
             end top-left, matching the site's `linear-gradient(-45deg, ...)`) that slides
             horizontally so the diagonal bands sweep across. Sized far beyond any window
             (covers up to 3920x2600) so the moving edge never enters view. -->
        <Canvas ClipToBounds="True" IsHitTestVisible="False">
            <Border Classes="flowGradient" Width="4400" Height="2600"
                    Canvas.Left="0" Canvas.Top="0" Opacity="0.18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="100%,100%" EndPoint="0%,0%">
                        <GradientStop Offset="0" Color="#EF1237"/>
                        <GradientStop Offset="0.33" Color="#9333EA"/>
                        <GradientStop Offset="0.66" Color="#3B82F6"/>
                        <GradientStop Offset="1" Color="#F43F5E"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Canvas>

        <Canvas IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Classes="blobA" Width="260" Height="260" Canvas.Left="-60" Canvas.Top="-40"
                     Fill="#26EF1237">
                <Ellipse.Effect>
                    <BlurEffect Radius="120"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Classes="blobB" Width="320" Height="320" Canvas.Right="-80" Canvas.Top="60"
                     Fill="#269333EA">
                <Ellipse.Effect>
                    <BlurEffect Radius="140"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Classes="blobC" Width="220" Height="220" Canvas.Left="280" Canvas.Bottom="-40"
                     Fill="#1F3B82F6">
                <Ellipse.Effect>
                    <BlurEffect Radius="120"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Classes="blobD" Width="200" Height="200" Canvas.Right="120" Canvas.Bottom="-30"
                     Fill="#26F43F5E">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid ColumnDefinitions="220,*" RowDefinitions="*,Auto">

            <Grid Grid.Column="0" Grid.Row="0" RowDefinitions="Auto,*,Auto">
                <StackPanel Grid.Row="0" Margin="22,28,22,32" Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="9"
                                ClipToBounds="True"
                                BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                            <Image Source="/Assets/BasisLogo.png" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Spacing="-2">
                            <TextBlock Text="{loc:Tr shell.wordmark.name}" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="{loc:Tr shell.wordmark.tagline}" FontSize="11" Classes="muted"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="0" Margin="10,0">
                    <Button Classes="nav" Classes.active="{Binding IsInstalls}" Tag="installs" Click="OnNavClick" Content="{loc:Tr nav.installs}"/>
                    <Grid>
                        <Button Classes="nav" Classes.active="{Binding IsCommunity}" Tag="community" Click="OnNavClick" HorizontalAlignment="Stretch" Content="{loc:Tr nav.community}"/>
                        <Border Classes="brandBadge" Padding="7,1" MinWidth="18"
                                HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0"
                                IsHitTestVisible="False"
                                IsVisible="{Binding HasUnreadAnnouncements}">
                            <TextBlock Text="{Binding AnnouncementsUnreadCount}"
                                       FontSize="10" FontWeight="Bold" Foreground="#FFFFFF"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <Button Classes="nav" Classes.active="{Binding IsPackages}" Tag="packages" Click="OnNavClick" Content="{loc:Tr nav.packages}"/>
                    <Button Classes="nav" Classes.active="{Binding IsDevelop}" Tag="develop" Click="OnNavClick" IsVisible="{Binding ShowDevelopTab}" Content="{loc:Tr nav.develop}"/>
                    <Button Classes="nav" Classes.active="{Binding IsChanges}" Tag="changes" Click="OnNavClick" IsVisible="{Binding ShowChangesTab}" Content="{loc:Tr nav.changes}"/>
                    <Button Classes="nav" Classes.active="{Binding IsUnity}" Tag="unity" Click="OnNavClick" Content="{loc:Tr nav.unity}"/>
                    <Button Classes="nav" Classes.active="{Binding IsSettings}" Tag="settings" Click="OnNavClick" Content="{loc:Tr nav.settings}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="22,0,22,22" Spacing="6">
                    <Rectangle Height="1" Fill="{StaticResource BasisBorderBrush}" Margin="0,0,0,12"/>
                    <Border Classes="versionPill" HorizontalAlignment="Left" Margin="0,0,0,4"
                            ToolTip.Tip="{loc:Tr shell.version.tooltip}">
                        <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}" FontSize="12" FontWeight="SemiBold" Classes="brand"/>
                    </Border>
                    <TextBlock Text="basisvr.org" Classes="dim" FontSize="11"/>
                    <TextBlock Text="{loc:Tr shell.footer.license}" Classes="dim" FontSize="11"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1" Grid.Row="0" RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        IsVisible="{Binding UpdateAvailable}"
                        Background="{StaticResource BasisBrandGradient}"
                        CornerRadius="12"
                        Padding="18,12" Margin="18,16,18,0">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Grid.Column="0" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UpdateBannerText}"
                                       Foreground="#FFFFFF" FontWeight="SemiBold" FontSize="13"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                            <ProgressBar IsVisible="{Binding IsUpdating}"
                                         Minimum="0" Maximum="100" Value="{Binding UpdateProgress}"
                                         ShowProgressText="True"
                                         Foreground="#FFFFFF" Background="#33FFFFFF"
                                         Height="16" CornerRadius="8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                    Margin="16,0,0,0" VerticalAlignment="Center"
                                    IsVisible="{Binding !IsUpdating}">
                            <Button Classes="bannerPrimary" Content="{loc:Tr shell.update.now}"
                                    Command="{Binding InstallUpdateCommand}"
                                    ToolTip.Tip="{loc:Tr shell.update.nowTooltip}"/>
                            <Button Classes="bannerGhost" Content="{loc:Tr shell.update.later}"
                                    Command="{Binding DismissUpdateCommand}"
                                    ToolTip.Tip="{loc:Tr shell.update.laterTooltip}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
            </Grid>

            <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                    Background="#A0100F27"
                    BorderBrush="{StaticResource BasisBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="18,9">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusMessage}"
                               Classes="muted"
                               Classes.statusError="{Binding IsStatusError}"
                               Classes.statusSuccess="{Binding IsStatusSuccess}"
                               FontSize="12" FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="12,0,0,0"
                                IsVisible="{Binding CanCopyStatus}">
                        <Button Content="{loc:Tr shell.status.copy}" Padding="10,4" FontSize="11"
                                Click="OnCopyStatusClick"
                                ToolTip.Tip="{loc:Tr shell.status.copyTooltip}"/>
                        <Button Content="{loc:Tr shell.status.openIssue}" Padding="10,4" FontSize="11"
                                IsVisible="{Binding IsStatusError}"
                                Command="{Binding OpenIssueCommand}"
                                ToolTip.Tip="{loc:Tr shell.status.openIssueTooltip}"/>
                        <Button Content="{loc:Tr shell.status.ok}" Padding="10,4" FontSize="11"
                                Click="OnDismissStatusClick"
                                ToolTip.Tip="{loc:Tr shell.status.okTooltip}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Panel>
</Window>
