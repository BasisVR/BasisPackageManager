<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="using:System"
        xmlns:loc="using:BasisPM.App.Localization"
        x:Class="BasisPM.App.Views.BranchPickerWindow"
        Title="{loc:Tr dialog.branchPicker.title}"
        Width="480" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BasisBackgroundBrush}">
    <Grid RowDefinitions="Auto,*,Auto" Margin="26">
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" Text="{loc:Tr dialog.branchPicker.title}" Classes="h3"/>
            <TextBlock x:Name="SubText" Classes="dim" FontSize="12" TextWrapping="Wrap"/>
        </StackPanel>
        <Border Grid.Row="1" Classes="card" Padding="4">
            <ListBox x:Name="List" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="sys:String">
                        <TextBlock Text="{Binding}" Margin="10,9" TextTrimming="CharacterEllipsis"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,14,0,0">
            <Button Click="OnCancel" ToolTip.Tip="{loc:Tr dialog.branchPicker.tooltip.cancel}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconClose}" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr dialog.branchPicker.cancel}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Classes="primary" Click="OnOk" ToolTip.Tip="{loc:Tr dialog.branchPicker.tooltip.switch}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconBranch}" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr dialog.branchPicker.switch}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
