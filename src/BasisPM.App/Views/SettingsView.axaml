<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             xmlns:loc="using:BasisPM.App.Localization"
             x:Class="BasisPM.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="24">

            <Border CornerRadius="14" Padding="32,28" Background="{StaticResource BasisHeroGradient}"
                    BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="{loc:Tr settings.hero.tagline}" Classes="tagline"/>
                    <TextBlock Text="{loc:Tr settings.hero.title}" Classes="h1"/>
                    <TextBlock Text="{loc:Tr settings.hero.subtitle}" Classes="muted" FontSize="14"/>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="{loc:Tr settings.language.title}" Classes="h3"/>
                    <TextBlock Text="{loc:Tr settings.language.description}"
                               Classes="muted" FontSize="12" TextWrapping="Wrap"/>
                    <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"
                              MinWidth="260" HorizontalAlignment="Left">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="loc:LanguageInfo">
                                <TextBlock Text="{Binding NativeName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="20">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{loc:Tr settings.clone.title}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr settings.clone.description}"
                                   Classes="muted" FontSize="12" TextWrapping="Wrap"/>
                        <TextBox Text="{Binding ClonePath}" Watermark="C:\Users\you\BasisVR"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{loc:Tr settings.catalog.title}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr settings.catalog.description}"
                                   Classes="muted" FontSize="12" TextWrapping="Wrap"/>
                        <TextBox Text="{Binding CatalogUrl}" Watermark="https://basisvr.org/packages/catalog.json"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{loc:Tr settings.extraCatalogs.title}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr settings.extraCatalogs.description}"
                                   Classes="muted" FontSize="12" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding ExtraCatalogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:CatalogUrlItem">
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                                        <TextBox Grid.Column="0" Text="{Binding Url}"/>
                                        <Button Grid.Column="1" Classes="iconBtn danger" Margin="8,0,0,0"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveCatalogCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:Tr settings.extraCatalogs.remove}">
                                            <PathIcon Width="14" Height="14" Data="{StaticResource IconClose}"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Text="{Binding NewCatalogUrl}"
                                     Watermark="{loc:Tr settings.extraCatalogs.watermark}"/>
                            <Button Grid.Column="1" Margin="8,0,0,0"
                                    Classes="primary" Command="{Binding AddCatalogCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconAdd}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Tr settings.extraCatalogs.add}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="{loc:Tr settings.unityHub.title}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr settings.unityHub.description}"
                                   Classes="muted" FontSize="12" TextWrapping="Wrap"/>
                        <TextBox Text="{Binding UnityHubPath}" Watermark="C:\Program Files\Unity Hub\Unity Hub.exe"/>
                    </StackPanel>

                    <CheckBox Content="{loc:Tr settings.toggle.localChanges}" IsChecked="{Binding ShowLocalChanges}"
                              ToolTip.Tip="{loc:Tr settings.toggle.localChanges.tip}"/>

                    <CheckBox Content="{loc:Tr settings.toggle.developer}" IsChecked="{Binding DeveloperMode}"
                              ToolTip.Tip="{loc:Tr settings.toggle.developer.tip}"/>

                    <CheckBox Content="{loc:Tr settings.toggle.prerelease}" IsChecked="{Binding PrereleaseUpdates}"
                              ToolTip.Tip="{loc:Tr settings.toggle.prerelease.tip}"/>

                    <Button Classes="primary" Command="{Binding SaveCommand}" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconSave}" VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Tr settings.button.save}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="{loc:Tr settings.detected.title}" Classes="h3"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="{loc:Tr settings.detected.git}" Classes="muted" FontSize="11"/>
                        <TextBlock Text="{Binding GitDetected}" Classes="dim" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="{loc:Tr settings.detected.unityHub}" Classes="muted" FontSize="11"/>
                        <TextBlock Text="{Binding HubDetected}" Classes="dim" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="{loc:Tr settings.detected.settingsFile}" Classes="muted" FontSize="11"/>
                        <TextBlock Text="{Binding SettingsPath}" Classes="dim" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="{loc:Tr settings.about.title}" Classes="h3"/>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Tr settings.about.version}" Classes="muted" FontSize="12" VerticalAlignment="Center"/>
                        <Border Classes="versionPill" VerticalAlignment="Center">
                            <TextBlock Text="{Binding AppVersion}" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <Button Command="{Binding CheckForUpdatesCommand}" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Classes="leadingIcon" Data="{StaticResource IconUpdate}" VerticalAlignment="Center"/>
                            <TextBlock Text="{loc:Tr settings.about.checkUpdates}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{loc:Tr settings.about.updatesBlurb}"
                               Classes="dim" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="{loc:Tr settings.logs.title}" Classes="h3"/>
                            <TextBlock Text="{loc:Tr settings.logs.description}"
                                       Classes="muted" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                            <Button Classes="iconBtn" Click="OnCopyLogs" ToolTip.Tip="{loc:Tr settings.logs.copy}">
                                <PathIcon Width="16" Height="16" Data="{StaticResource IconCopy}"/>
                            </Button>
                            <Button Classes="iconBtn" Command="{Binding Logs.OpenFolderCommand}" ToolTip.Tip="{loc:Tr settings.logs.openFolder}">
                                <PathIcon Width="16" Height="16" Data="{StaticResource IconFolderOpen}"/>
                            </Button>
                            <Button Classes="iconBtn" Command="{Binding Logs.ClearCommand}" ToolTip.Tip="{loc:Tr settings.logs.clear}">
                                <PathIcon Width="16" Height="16" Data="{StaticResource IconDelete}"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Border Background="{StaticResource BasisPanelBrush}" BorderBrush="{StaticResource BasisBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="0" MaxHeight="340">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding Logs.Entries}" Margin="8,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:LogRow">
                                        <Grid ColumnDefinitions="Auto,*" Margin="12,2">
                                            <TextBlock Grid.Column="0" Text="{Binding Time}" Classes="dim"
                                                       FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Message}" Foreground="{Binding Brush}"
                                                       FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Licenses & attributions: every third-party component bundled in the app, its
                 licence, copyright and source. The interface icons (Fluent System Icons) are
                 credited here too, per the project's attribution requirements. -->
            <Border Classes="card">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <PathIcon Width="18" Height="18" Data="{StaticResource IconLicense}" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr settings.licenses.title}" Classes="h3" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{loc:Tr settings.licenses.description}" Classes="muted" FontSize="12" TextWrapping="Wrap"/>

                    <StackPanel Spacing="8">
                        <Border Classes="glass" Padding="14,12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Basis Package Manager" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{loc:Tr settings.licenses.role.thisApp}" Classes="muted" FontSize="11"/>
                                    <TextBlock Text="© 2026 BasisVR · github.com/BasisVR/BasisPackageManager" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1" Classes="versionPill" VerticalAlignment="Center" ToolTip.Tip="MIT License">
                                    <TextBlock Text="MIT" FontSize="11" FontWeight="SemiBold" Classes="muted"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Classes="glass" Padding="14,12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Avalonia" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{loc:Tr settings.licenses.role.framework}" Classes="muted" FontSize="11"/>
                                    <TextBlock Text="© .NET Foundation and Contributors · avaloniaui.net" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1" Classes="versionPill" VerticalAlignment="Center" ToolTip.Tip="MIT License">
                                    <TextBlock Text="MIT" FontSize="11" FontWeight="SemiBold" Classes="muted"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Classes="glass" Padding="14,12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Fluent System Icons" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{loc:Tr settings.licenses.role.icons}" Classes="muted" FontSize="11"/>
                                    <TextBlock Text="© Microsoft Corporation · github.com/microsoft/fluentui-system-icons" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1" Classes="versionPill" VerticalAlignment="Center" ToolTip.Tip="MIT License">
                                    <TextBlock Text="MIT" FontSize="11" FontWeight="SemiBold" Classes="muted"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Classes="glass" Padding="14,12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Inter" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{loc:Tr settings.licenses.role.font}" Classes="muted" FontSize="11"/>
                                    <TextBlock Text="© The Inter Project Authors · rsms.me/inter" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1" Classes="versionPill" VerticalAlignment="Center" ToolTip.Tip="SIL Open Font License 1.1">
                                    <TextBlock Text="OFL 1.1" FontSize="11" FontWeight="SemiBold" Classes="muted"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Classes="glass" Padding="14,12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Velopack" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{loc:Tr settings.licenses.role.updater}" Classes="muted" FontSize="11"/>
                                    <TextBlock Text="© Caelan Sayler &amp; Velopack contributors · velopack.io" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1" Classes="versionPill" VerticalAlignment="Center" ToolTip.Tip="MIT License">
                                    <TextBlock Text="MIT" FontSize="11" FontWeight="SemiBold" Classes="muted"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Border Classes="glass" Padding="14,12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text=".NET" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{loc:Tr settings.licenses.role.runtime}" Classes="muted" FontSize="11"/>
                                    <TextBlock Text="© .NET Foundation and Contributors · dotnet.microsoft.com" Classes="dim" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1" Classes="versionPill" VerticalAlignment="Center" ToolTip.Tip="MIT License">
                                    <TextBlock Text="MIT" FontSize="11" FontWeight="SemiBold" Classes="muted"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
