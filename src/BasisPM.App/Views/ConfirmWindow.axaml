<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:BasisPM.App.Localization"
        x:Class="BasisPM.App.Views.ConfirmWindow"
        Title="{loc:Tr dialog.confirm.title}"
        Width="440" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BasisBackgroundBrush}">
    <StackPanel Margin="26,24" Spacing="18">
        <TextBlock x:Name="TitleText" Text="{loc:Tr dialog.confirm.title}" Classes="h3"/>
        <TextBlock x:Name="MessageText" Classes="muted" FontSize="13" TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Click="OnNo" ToolTip.Tip="{loc:Tr dialog.confirm.tooltip.no}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconClose}" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr dialog.confirm.no}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Classes="primary" Click="OnYes" ToolTip.Tip="{loc:Tr dialog.confirm.tooltip.yes}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconCheck}" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr dialog.confirm.yes}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
