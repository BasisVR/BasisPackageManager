<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:BasisPM.App.Views"
        xmlns:loc="using:BasisPM.App.Localization"
        x:Class="BasisPM.App.Views.PackageListPickerWindow"
        Title="{loc:Tr dialog.packageListPicker.title}"
        Width="540" Height="470"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BasisBackgroundBrush}">
    <Grid RowDefinitions="Auto,*,Auto" Margin="26">
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,14">
            <TextBlock Text="{loc:Tr dialog.packageListPicker.heading}" Classes="h3"/>
            <TextBlock Text="{loc:Tr dialog.packageListPicker.subtitle}" Classes="dim" FontSize="12"/>
        </StackPanel>
        <Border Grid.Row="1" Classes="card" Padding="4">
            <ListBox x:Name="List" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="views:PackageListPickerRow">
                        <Grid ColumnDefinitions="Auto,*" Margin="10,10">
                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="20" VerticalAlignment="Top" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}" Classes="dim" FontSize="11" TextWrapping="Wrap"
                                           IsVisible="{Binding HasDescription}"/>
                                <TextBlock Text="{Binding CountLabel}" Classes="muted" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,14,0,0">
            <Button Click="OnCancel">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconClose}" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr dialog.installPicker.cancel}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Classes="primary" Click="OnOk">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconDownload}" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr packages.button.install}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
