<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             xmlns:loc="using:BasisPM.App.Localization"
             x:Class="BasisPM.App.Views.DocumentationView"
             x:DataType="vm:DocumentationViewModel">

    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="20">

            <Border CornerRadius="14" Padding="32,28"
                    Background="{StaticResource BasisHeroGradient}"
                    BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="{loc:Tr docs.hero.tagline}" Classes="tagline"/>
                    <TextBlock Text="{loc:Tr docs.hero.title}" Classes="h1"/>
                    <TextBlock Text="{loc:Tr docs.hero.subtitle}"
                               Classes="muted" FontSize="14" TextWrapping="Wrap" MaxWidth="660" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                        <Button Classes="primary" Command="{Binding DocsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconBook}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr docs.button.openDocs}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DiscordCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconChat}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr docs.button.askDiscord}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*">
                <Border Grid.Column="0" Classes="card" Margin="0,0,10,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:Tr docs.site.title}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr docs.site.body}"
                                   Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                        <Button Command="{Binding DocsCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconOpenExternal}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr docs.button.openDocsSite}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Margin="10,0,0,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:Tr docs.community.title}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr docs.community.body}"
                                   Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                        <Button Command="{Binding DiscordCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconChat}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr docs.button.joinDiscord}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="{loc:Tr docs.source.title}" Classes="h3"/>
                    <TextBlock Text="{loc:Tr docs.source.body}"
                               Classes="muted" FontSize="13" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Command="{Binding BasisRepoCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconOpenExternal}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr docs.button.basisGithub}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding PackageManagerRepoCommand}" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Classes="leadingIcon" Data="{StaticResource IconOpenExternal}" VerticalAlignment="Center"/>
                                <TextBlock Text="{loc:Tr docs.button.packageManagerGithub}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
