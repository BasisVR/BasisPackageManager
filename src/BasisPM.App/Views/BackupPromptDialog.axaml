<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:BasisPM.App.Localization"
        x:Class="BasisPM.App.Views.BackupPromptDialog"
        Title="{loc:Tr dialog.backup.title}"
        Width="480" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BasisBackgroundBrush}">
    <StackPanel Margin="26,24" Spacing="18">
        <TextBlock Text="{loc:Tr dialog.backup.heading}" Classes="h3"/>
        <TextBlock x:Name="MessageText" Classes="muted" FontSize="13" TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Content="{loc:Tr dialog.backup.cancel}" Click="OnCancel"/>
            <Button Content="{loc:Tr dialog.backup.continueWithout}" Click="OnContinue"/>
            <Button Classes="primary" Content="{loc:Tr dialog.backup.backupContinue}" Click="OnBackup"/>
        </StackPanel>
    </StackPanel>
</Window>
