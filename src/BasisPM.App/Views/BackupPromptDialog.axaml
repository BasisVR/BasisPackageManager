<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BasisPM.App.Views.BackupPromptDialog"
        Title="Back up your project?"
        Width="480" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BasisBackgroundBrush}">
    <StackPanel Margin="26,24" Spacing="18">
        <TextBlock Text="Back up your project first?" Classes="h3"/>
        <TextBlock x:Name="MessageText" Classes="muted" FontSize="13" TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancel"/>
            <Button Content="Continue without backup" Click="OnContinue"/>
            <Button Classes="primary" Content="Back up &amp; continue" Click="OnBackup"/>
        </StackPanel>
    </StackPanel>
</Window>
