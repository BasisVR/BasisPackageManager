<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:BasisPM.App.Localization"
        x:Class="BasisPM.App.Views.BackupPromptDialog"
        Title="{loc:Tr dialog.backup.title}"
        SizeToContent="WidthAndHeight" MinWidth="480" MaxWidth="720"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BasisBackgroundBrush}">
    <StackPanel Margin="26,24" Spacing="18">
        <TextBlock Text="{loc:Tr dialog.backup.heading}" Classes="h3"/>
        <!-- Cap the wrap width so a long message stays readable; the window still grows wider than
             this if the (localized) button row needs it, so the buttons never overflow off-screen. -->
        <TextBlock x:Name="MessageText" Classes="muted" FontSize="13" TextWrapping="Wrap" MaxWidth="520"/>
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Click="OnCancel">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconClose}" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr dialog.backup.cancel}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Content="{loc:Tr dialog.backup.continueWithout}" Click="OnContinue"/>
            <Button Classes="primary" Click="OnBackup">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconArchive}" VerticalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr dialog.backup.backupContinue}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
