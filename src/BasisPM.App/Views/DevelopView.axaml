<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BasisPM.App.ViewModels"
             xmlns:loc="using:BasisPM.App.Localization"
             x:Class="BasisPM.App.Views.DevelopView"
             x:DataType="vm:DevelopViewModel"
             Name="Root">

    <ScrollViewer>
        <StackPanel Margin="40,32" Spacing="20">

            <Border CornerRadius="14" Padding="32,28" Background="{StaticResource BasisHeroGradient}"
                    BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="{loc:Tr develop.header.tagline}" Classes="tagline"/>
                        <TextBlock Text="{Binding InstallName}" Classes="h1"/>
                        <TextBlock Text="{loc:Tr develop.header.description}"
                                   Classes="muted" FontSize="14" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Classes="iconBtn" Command="{Binding RefreshCommand}" VerticalAlignment="Top" ToolTip.Tip="{loc:Tr develop.button.refresh}">
                        <PathIcon Width="16" Height="16" Data="{StaticResource IconRefresh}"/>
                    </Button>
                </Grid>
            </Border>

            <Border Classes="card" IsVisible="{Binding !HasInstall}">
                <StackPanel Spacing="10" HorizontalAlignment="Center" Margin="0,50">
                    <TextBlock Text="{loc:Tr develop.empty.title}" Classes="h3" HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Tr develop.empty.description}"
                               Classes="muted" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Spacing="20" IsVisible="{Binding HasInstall}">

                <!-- Preflight: Git -->
                <Border Classes="card" Padding="20,16" IsVisible="{Binding GitMissing}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{loc:Tr develop.git.requiredTitle}" Classes="h3"/>
                        <TextBlock Text="{loc:Tr develop.git.requiredDescription}"
                                   Classes="muted" FontSize="12" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Classes="primary" Command="{Binding InstallGitCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconDownload}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Tr develop.button.installGit}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="iconBtn" Command="{Binding RecheckCommand}" ToolTip.Tip="{loc:Tr develop.button.recheck}">
                                <PathIcon Width="16" Height="16" Data="{StaticResource IconRefresh}"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Preflight: GitHub sign-in -->
                <Border Classes="card" Padding="20,16">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding AuthLabel}" Classes="muted" FontSize="12"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <Button Grid.Column="1" Classes="iconBtn" Command="{Binding RecheckCommand}" VerticalAlignment="Top" ToolTip.Tip="{loc:Tr develop.button.recheck}">
                                <PathIcon Width="16" Height="16" Data="{StaticResource IconRefresh}"/>
                            </Button>
                        </Grid>
                        <StackPanel Spacing="6" IsVisible="{Binding ShowPatEntry}">
                            <TextBlock Text="{loc:Tr develop.auth.tokenLabel}" Classes="muted" FontSize="11"/>
                            <Grid ColumnDefinitions="*,8,Auto">
                                <TextBox Grid.Column="0" Text="{Binding PatInput}" PasswordChar="•"
                                         Watermark="{loc:Tr develop.auth.tokenWatermark}"/>
                                <Button Grid.Column="2" Classes="primary" Command="{Binding ApplyPatCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconKey}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{loc:Tr develop.button.signIn}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Git packages (mountable) -->
                <Border Classes="card" Padding="0">
                    <StackPanel>
                        <Border Padding="20,16" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="{loc:Tr develop.section.gitPackages}" Classes="h3" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                                            Margin="0,0,10,0" IsVisible="{Binding HasOwnerChoices}">
                                    <TextBlock Text="{loc:Tr develop.owner.label}" Classes="muted" FontSize="12" VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding Owners}" SelectedItem="{Binding SelectedOwner}"
                                              MinWidth="170" MaxDropDownHeight="320">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="vm:OwnerOption">
                                                <TextBlock Text="{Binding Display}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <Button Grid.Column="2" Classes="primary"
                                        Command="{Binding MountAllCommand}" IsVisible="{Binding HasGitPackages}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconAdd}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{loc:Tr develop.button.mountAll}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                        <ItemsControl ItemsSource="{Binding GitPackages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:GitPackageRow">
                                    <Border Padding="20,14" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <StackPanel Grid.Column="0" Spacing="3">
                                                <TextBlock Text="{Binding Id}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Slug}" Classes="dim" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Classes="primary"
                                                    Command="{Binding #Root.((vm:DevelopViewModel)DataContext).MountCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconEdit}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Tr develop.button.mountToEdit}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{loc:Tr develop.section.noGitPackages}" Classes="muted" FontSize="12"
                                   Margin="20,16" IsVisible="{Binding NoGitPackages}"/>
                    </StackPanel>
                </Border>

                <!-- Accidental edits in Library/PackageCache -->
                <Border Classes="card" Padding="0">
                    <StackPanel>
                        <Border Padding="20,16" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="{loc:Tr develop.section.cacheChanges}" Classes="h3"/>
                                    <TextBlock Text="{loc:Tr develop.section.cacheChangesHint}" Classes="muted" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Command="{Binding ScanDriftCommand}" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconSearch}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{loc:Tr develop.button.scanCache}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                        <ItemsControl ItemsSource="{Binding DriftPackages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:CacheDriftRow">
                                    <Border Padding="20,14" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <StackPanel Grid.Column="0" Spacing="3" ClipToBounds="True">
                                                <TextBlock Text="{Binding PackageId}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding ChangedSummary}" Classes="dim" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Classes="primary"
                                                    Command="{Binding #Root.((vm:DevelopViewModel)DataContext).OpenDriftPrCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <PathIcon Classes="leadingIcon" Data="{StaticResource IconBranch}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Tr develop.button.reviewOpenPr}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{loc:Tr develop.section.noCacheChanges}" Classes="muted" FontSize="12"
                                   Margin="20,16" IsVisible="{Binding NoDrift}"/>
                    </StackPanel>
                </Border>

                <!-- Mounted for editing -->
                <Border Classes="card" Padding="0" IsVisible="{Binding HasMounted}">
                    <StackPanel>
                        <Border Padding="20,16" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="{loc:Tr develop.section.mountedForEditing}" Classes="h3"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding Mounted}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:MountedRow">
                                    <Border Padding="20,14" BorderBrush="{StaticResource BasisBorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <StackPanel Grid.Column="0" Spacing="3" ClipToBounds="True">
                                                <TextBlock Text="{Binding Id}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding FolderPath}" Classes="dim" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Button Command="{Binding #Root.((vm:DevelopViewModel)DataContext).OpenInUnityCommand}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconPlay}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{loc:Tr develop.button.openInUnity}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding #Root.((vm:DevelopViewModel)DataContext).SwapBackCommand}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconUndo}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{loc:Tr develop.button.swapBack}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="primary"
                                                        Command="{Binding #Root.((vm:DevelopViewModel)DataContext).SubmitPrCommand}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <PathIcon Classes="leadingIcon" Data="{StaticResource IconBranch}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{loc:Tr develop.button.submitPr}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
